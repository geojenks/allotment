---
interface Props {
  title?: string;
  active?: 'today' | 'layout' | 'pipeline' | 'calendar' | 'seeds' | 'nursery' | 'projects' | 'plans';
  wide?: boolean;
}
const { title = 'Allotment', active = 'layout', wide = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

const tabs = [
  { key: 'today', href: base, label: 'Today' },
  { key: 'layout', href: `${base}map`, label: 'Map' },
  { key: 'pipeline', href: `${base}pipeline`, label: 'Pipeline' },
  { key: 'calendar', href: `${base}calendar`, label: 'Calendar' },
  { key: 'seeds', href: `${base}seeds`, label: 'Seeds' },
  { key: 'plans', href: `${base}plans`, label: 'Plans' },
  { key: 'projects', href: `${base}projects`, label: 'Projects' },
];

const bbar = [
  { key: 'today', href: base, label: 'Today', icon: '🏠' },
  { key: 'layout', href: `${base}map`, label: 'Map', icon: '🗺️' },
  { key: 'pipeline', href: `${base}pipeline`, label: 'Pipeline', icon: '🌱' },
  { key: 'calendar', href: `${base}calendar`, label: 'Calendar', icon: '📅' },
];
const more = [
  { href: `${base}seeds`, label: 'Seeds', icon: '🌰' },
  { href: `${base}plans`, label: 'Plans', icon: '🗓️' },
  { href: `${base}projects`, label: 'Projects', icon: '🔨' },
  { href: `${base}map#home-greenhouse`, label: 'Greenhouse', icon: '🏡' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="A living plan and journal for the allotment." />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>
        <span class="brand__mark" aria-hidden="true"></span>
        <span class="brand__name">Allotment</span>
      </a>
      <nav class="tabs" aria-label="Sections">
        {
          tabs.map((t) => (
            <a
              href={t.href}
              class:list={['tab', { 'is-active': t.key === active }]}
              aria-current={t.key === active ? 'page' : undefined}
            >
              {t.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main class:list={['main', { 'main--wide': wide }]}>
      <slot />
    </main>

    <footer class="site-footer">
      <span>15&nbsp;m plot</span>
      <span class="dot">·</span>
      <span>planted, planned &amp; in&nbsp;progress</span>
    </footer>

    <div id="more-sheet" class="more-sheet" hidden>
      {more.map((m) => (
        <a href={m.href}><span>{m.icon}</span>{m.label}</a>
      ))}
    </div>
    <nav class="bbar" aria-label="Quick sections">
      {bbar.map((t) => (
        <a href={t.href} class:list={['bbar__item', { 'is-active': t.key === active }]}>
          <span class="bbar__icon">{t.icon}</span>{t.label}
        </a>
      ))}
      <button id="bbar-more" class="bbar__item" type="button">
        <span class="bbar__icon">⋯</span>More
      </button>
    </nav>
    <script is:inline>
      (() => {
        const btn = document.getElementById('bbar-more');
        const sheet = document.getElementById('more-sheet');
        if (!btn || !sheet) return;
        btn.addEventListener('click', () => { sheet.hidden = !sheet.hidden; });
        document.addEventListener('click', (e) => { if (!sheet.hidden && !sheet.contains(e.target) && e.target !== btn && !btn.contains(e.target)) sheet.hidden = true; });
      })();
    </script>

    <style is:global>
      :root {
        --paper: #fbfaf6;
        --paper-2: #f3f1e9;
        --panel: #ffffff;
        --ink: #1b2019;
        --ink-soft: #3c4339;
        --muted: #767c70;
        --line: #e7e3d8;
        --line-strong: #d8d3c5;
        --green: #356a45;
        --green-700: #2a5538;
        --green-100: #e7efe6;
        --accent: #c2622d;
        --accent-soft: #f4e3d6;
        --shadow-sm: 0 1px 2px rgba(30, 40, 25, 0.05);
        --shadow: 0 10px 30px -12px rgba(30, 45, 25, 0.22);
        --radius: 14px;
        --radius-sm: 10px;
        --maxw: 1180px;
        --header-h: 60px;
        font-synthesis: none;
        -webkit-text-size-adjust: 100%;
      }

      * {
        box-sizing: border-box;
      }
      /* `hidden` must win over our display:flex/grid rules. */
      [hidden] {
        display: none !important;
      }
      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Hanken Grotesk', ui-sans-serif, system-ui, sans-serif;
        color: var(--ink);
        background-color: var(--paper);
        background-image:
          radial-gradient(900px 500px at 100% -5%, #eef3e8, transparent 60%),
          radial-gradient(700px 400px at -10% 0%, #f6efe6, transparent 55%);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        line-height: 1.55;
        font-size: 16px;
        letter-spacing: -0.005em;
      }

      h1,
      h2,
      h3,
      .display {
        font-family: 'Bricolage Grotesque', 'Hanken Grotesk', sans-serif;
        font-weight: 700;
        line-height: 1.08;
        letter-spacing: -0.02em;
        color: var(--ink);
        margin: 0;
      }

      a {
        color: var(--green-700);
      }

      /* ---------- header ---------- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        height: var(--header-h);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0 clamp(1rem, 4vw, 2rem);
        background: color-mix(in srgb, var(--paper) 82%, transparent);
        backdrop-filter: saturate(1.4) blur(10px);
        border-bottom: 1px solid var(--line);
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        text-decoration: none;
        color: var(--ink);
      }
      .brand__mark {
        width: 16px;
        height: 16px;
        border-radius: 50% 50% 50% 0;
        background: linear-gradient(150deg, var(--green) 0%, var(--green-700) 100%);
        transform: rotate(-12deg);
        box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--green) 60%, white 0%);
      }
      .brand__name {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-weight: 800;
        font-size: 1.18rem;
        letter-spacing: -0.03em;
      }

      .tabs {
        display: flex;
        align-items: center;
        gap: clamp(0.5rem, 2vw, 1rem);
        overflow-x: auto;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
        margin: 0 -0.5rem;
        padding: 0 0.5rem;
      }
      .tabs::-webkit-scrollbar {
        display: none;
      }
      .tab {
        position: relative;
        text-decoration: none;
        color: var(--muted);
        font-weight: 600;
        font-size: 0.95rem;
        padding: 0.4rem 0.15rem;
        white-space: nowrap;
        transition: color 0.18s ease;
      }
      .tab::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: -2px;
        height: 2px;
        border-radius: 2px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 0.22s cubic-bezier(0.2, 0.7, 0.3, 1);
      }
      .tab:hover {
        color: var(--ink);
      }
      .tab.is-active {
        color: var(--ink);
      }
      .tab.is-active::after {
        transform: scaleX(1);
      }

      /* ---------- layout ---------- */
      .main {
        flex: 1;
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: clamp(1.1rem, 3vw, 2rem) clamp(1rem, 4vw, 2rem) 2.5rem;
      }
      .main--wide {
        max-width: none;
        padding-left: clamp(1rem, 3vw, 1.6rem);
        padding-right: clamp(1rem, 3vw, 1.6rem);
      }

      .site-footer {
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.82rem;
        display: flex;
        gap: 0.4rem;
        justify-content: center;
        padding: 1.1rem;
      }
      .site-footer .dot {
        opacity: 0.5;
      }

      /* ---------- shared building blocks ---------- */
      .page-head {
        margin-bottom: clamp(1rem, 3vw, 1.8rem);
      }
      .page-head .eyebrow {
        font-size: 0.74rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.35rem;
      }
      .page-head h1 {
        font-size: clamp(1.8rem, 4.5vw, 2.6rem);
      }
      .page-head p {
        color: var(--muted);
        max-width: 60ch;
        margin: 0.5rem 0 0;
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.16rem 0.6rem;
        border-radius: 999px;
        background: var(--green-100);
        color: var(--green-700);
        border: 1px solid color-mix(in srgb, var(--green) 22%, white);
      }

      /* ---------- phone bottom bar ---------- */
      .bbar { display: none; }
      .more-sheet { display: none; }
      @media (max-width: 820px) {
        .site-header .tabs { display: none; }
        body { padding-bottom: calc(3.6rem + env(safe-area-inset-bottom)); }
        .bbar {
          display: flex;
          position: fixed;
          left: 0; right: 0; bottom: 0;
          z-index: 90;
          background: color-mix(in srgb, var(--paper) 90%, transparent);
          backdrop-filter: saturate(1.4) blur(10px);
          border-top: 1px solid var(--line);
          padding: 0.3rem 0.4rem calc(0.35rem + env(safe-area-inset-bottom));
        }
        .bbar__item {
          flex: 1;
          display: flex; flex-direction: column; align-items: center; gap: 0.05rem;
          font: inherit; font-size: 0.62rem; font-weight: 600;
          color: var(--muted); text-decoration: none;
          background: transparent; border: 0; cursor: pointer;
          padding: 0.15rem 0; border-radius: 10px;
        }
        .bbar__icon { font-size: 1.15rem; line-height: 1.2; }
        .bbar__item.is-active { color: var(--green-700); background: var(--green-100); }
        .more-sheet {
          display: flex; flex-direction: column; gap: 0.1rem;
          position: fixed; right: 0.6rem; bottom: calc(3.8rem + env(safe-area-inset-bottom));
          z-index: 95;
          background: var(--panel); border: 1px solid var(--line);
          border-radius: var(--radius); box-shadow: var(--shadow);
          padding: 0.4rem;
        }
        .more-sheet[hidden] { display: none; }
        .more-sheet a { display: flex; align-items: center; gap: 0.55rem; text-decoration: none; color: var(--ink); font-weight: 600; font-size: 0.92rem; padding: 0.5rem 0.9rem; border-radius: 10px; }
        .more-sheet a:active { background: var(--green-100); }
        /* full-screen surfaces sit above the bar */
        body.plot-fs .bbar, body.av-open .bbar, body.plot-fs .more-sheet, body.av-open .more-sheet { display: none; }
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0.001ms !important;
          transition-duration: 0.001ms !important;
        }
      }
    </style>
  </body>
</html>
