---
import Base from '../layouts/Base.astro';
---

<Base title="Allotment — Calendar" active="calendar">
  <header class="page-head">
    <p class="eyebrow">What's happening when</p>
    <h1>Calendar</h1>
    <p>Sowings, plant-outs, harvests, jobs and rain — tap a day to see everything or log what you did (watering, weeding, project work).</p>
  </header>

  <div id="bar" class="savebar" hidden>
    <span class="savebar__label">Unsaved diary entries</span>
    <button id="publish" class="ctl ctl--primary" type="button">Save to website</button>
    <button id="discard" class="ctl ctl--ghost" type="button">Discard</button>
    <span id="bar-status" class="savebar__status"></span>
  </div>

  <div id="sownow" class="sownow" hidden>
    <strong>Sow this month:</strong> <span id="sownow-list"></span>
    <a href="../seeds">seed bank →</a>
  </div>

  <div id="wx" class="wx" hidden></div>

  <div class="cal-bar">
    <div class="nav">
      <button id="prev" class="navbtn" type="button" aria-label="Previous month">‹</button>
      <h2 id="month-label"></h2>
      <button id="next" class="navbtn" type="button" aria-label="Next month">›</button>
      <button id="today" class="ctl" type="button">Today</button>
    </div>
    <div class="filters">
      <select id="f-area" class="filt" aria-label="Filter by bed"></select>
      <select id="f-crop" class="filt" aria-label="Filter by crop"></select>
    </div>
  </div>

  <div id="legend" class="legend2"></div>

  <div class="cal-wrap">
    <div class="dow" id="dow"></div>
    <div id="grid" class="grid"></div>
  </div>

  <div id="month-list" class="month-list"></div>

  <dialog id="day-dialog" class="dialog"><div id="day-body" class="day-body"></div></dialog>
</Base>

<script>
  import areasData from '../data/areas.json';
  import seedsData from '../data/seeds.json';
  import logData from '../data/log.json';
  import plansData from '../data/plans.json';
  import { scopeStamp, PLOT_LOCATION, getToken, commitFiles, overlayLoad, overlaySave, overlayClear, uid, todayStr } from '../lib/datastore';

  const stamp = scopeStamp(document.getElementById('grid'));
  const SITE_BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

  const CATS = {
    sow: { label: 'Sow', color: '#5f8a36', emoji: '🌱' },
    plant: { label: 'Plant out', color: '#2f7d5a', emoji: '🪴' },
    harvest: { label: 'Harvest', color: '#c2622d', emoji: '🧺' },
    prune: { label: 'Prune', color: '#8a5fb0', emoji: '✂️' },
    water: { label: 'Watered', color: '#3f86ad', emoji: '🚿' },
    'weed-light': { label: 'Light weeding', color: '#8bb04f', emoji: '🌿' },
    'weed-heavy': { label: 'Heavy weeding', color: '#55702c', emoji: '🌿' },
    project: { label: 'Project work', color: '#9a7b4f', emoji: '🔨' },
    build: { label: 'Build', color: '#9a7b4f', emoji: '🧱' },
    job: { label: 'Job', color: '#64748b', emoji: '🔧' },
  };
  /** Categories you can log yourself from the day popup. */
  const LOG_CATS = ['water', 'weed-light', 'weed-heavy', 'project', 'harvest', 'job'];

  const LOG_KEY = 'allotment:log:v1';
  const LOG_PATH = 'src/data/log.json';
  let log = overlayLoad(LOG_KEY, logData);
  let logBaseline = JSON.stringify(logData);
  const logDirty = () => JSON.stringify(log) !== logBaseline;
  const bar = document.getElementById('bar');
  const barStatus = document.getElementById('bar-status');
  const saveLog = () => { overlaySave(LOG_KEY, log); bar.hidden = !logDirty(); };
  const LOC = { greenhouse: 'Greenhouse', polytunnel: 'Polytunnel', nursery: 'Nursery bed', windowsill: 'Windowsill', outdoor: 'Direct outdoors' };
  const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
  const DOW = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
  const areaName = (id) => areasData.areas.find((a) => a.id === id)?.name;

  // ---- build events ------------------------------------------------------
  let events = [];
  function buildEvents() {
    events = [];
    const push = (e) => events.push(e);
    for (const area of areasData.areas) {
      for (const p of area.plantings ?? []) {
        if (p.sown) push({ date: p.sown, cat: 'sow', title: p.crop, areaId: area.id, area: area.name, crop: p.crop });
        if (p.planted) push({ date: p.planted, cat: 'plant', title: p.crop, areaId: area.id, area: area.name, crop: p.crop });
        if (p.harvestFrom) push({ date: p.harvestFrom, cat: 'harvest', title: p.crop, areaId: area.id, area: area.name, crop: p.crop, detail: p.harvestTo ? 'until ' + p.harvestTo : '' });
      }
      for (const t of area.tasks ?? []) {
        const date = t.due ?? t.windowFrom;
        if (date) push({ date, cat: t.category || 'job', title: t.title, areaId: area.id, area: area.name, crop: '', detail: t.notes });
      }
    }
    for (const s of seedsData.sowings ?? []) {
      const name = `${s.crop}${s.variety ? ' · ' + s.variety : ''}`;
      push({ date: s.sownDate, cat: 'sow', title: name, areaId: '', area: LOC[s.location] || s.location, crop: s.crop });
      if (s.plantedOutDate) push({ date: s.plantedOutDate, cat: 'plant', title: name, areaId: s.destinationAreaId || '', area: s.destinationAreaId ? areaName(s.destinationAreaId) || 'allotment' : 'allotment', crop: s.crop });
    }
    for (const en of log.entries ?? []) {
      push({ date: en.date, cat: en.category, title: en.title || (CATS[en.category] || CATS.job).label, areaId: en.areaId || '', area: en.areaId ? areaName(en.areaId) || '' : '', crop: '', detail: en.notes, logId: en.id });
    }
    // bed plans (Plans page): back-propagated sow-by + plant-out reminders
    const NW = { brassica: 6, legume: 3, allium: 9, solanaceae: 8, apiaceae: 5, cucurbit: 4, chenopod: 4, other: 6, flower: 6 };
    const plans = overlayLoad('allotment:plans:v1', plansData);
    const fmtLocal = (d) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    for (const p of plans.plans ?? []) {
      const what = p.crops?.length ? p.crops.join(', ') : p.family;
      const bed = areaName(p.areaId) || '';
      push({ date: p.from + '-01', cat: 'plant', title: `Plan: ${what}`, areaId: p.areaId, area: bed, crop: '', detail: 'planned plant-out (approximate)' });
      const sowBy = new Date(p.from + '-01T00:00:00'); sowBy.setDate(sowBy.getDate() - (NW[p.family] ?? 6) * 7);
      push({ date: fmtLocal(sowBy), cat: 'sow', title: `Plan: sow ${what}`, areaId: p.areaId, area: bed, crop: '', detail: `~${NW[p.family] ?? 6} wks under glass, planting out ${p.from} in ${bed}` });
    }
  }
  buildEvents();

  const crops = [...new Set(events.map((e) => e.crop).filter(Boolean))].sort();

  // ---- state -------------------------------------------------------------
  const today = new Date(); today.setHours(0, 0, 0, 0);
  let view = new Date(today.getFullYear(), today.getMonth(), 1);
  const active = new Set(Object.keys(CATS));
  let fArea = '', fCrop = '';
  const visible = (e) => active.has(e.cat) && (!fArea || e.areaId === fArea) && (!fCrop || e.crop === fCrop);

  // ---- chrome ------------------------------------------------------------
  const dowEl = document.getElementById('dow');
  for (const d of DOW) { const s = document.createElement('span'); s.textContent = d; dowEl.append(s); }
  stamp(dowEl);

  const legend = document.getElementById('legend');
  for (const [key, c] of Object.entries(CATS)) {
    const b = document.createElement('button'); b.type = 'button'; b.className = 'lgd is-on'; b.dataset.cat = key;
    b.style.setProperty('--c', c.color);
    const dot = document.createElement('span'); dot.className = 'lgd__dot';
    b.append(dot, document.createTextNode(c.label));
    b.addEventListener('click', () => { if (active.has(key)) active.delete(key); else active.add(key); b.classList.toggle('is-on', active.has(key)); render(); });
    legend.append(b);
  }
  stamp(legend);

  const fArs = document.getElementById('f-area');
  fArs.append(new Option('All beds', ''));
  for (const a of areasData.areas) fArs.append(new Option(a.name, a.id));
  fArs.addEventListener('change', () => { fArea = fArs.value; render(); });
  const fCrs = document.getElementById('f-crop');
  fCrs.append(new Option('All crops', ''));
  for (const c of crops) fCrs.append(new Option(c, c));
  fCrs.addEventListener('change', () => { fCrop = fCrs.value; render(); });

  document.getElementById('prev').addEventListener('click', () => { view.setMonth(view.getMonth() - 1); render(); });
  document.getElementById('next').addEventListener('click', () => { view.setMonth(view.getMonth() + 1); render(); });
  document.getElementById('today').addEventListener('click', () => { view = new Date(today.getFullYear(), today.getMonth(), 1); render(); });

  // sow-now strip
  const nowMonth = today.getMonth() + 1;
  const monthIn = (m, w) => (w ? (w.from <= w.to ? m >= w.from && m <= w.to : m >= w.from || m <= w.to) : false);
  const sowNow = [];
  for (const s of seedsData.seeds ?? []) {
    if (monthIn(nowMonth, s.sowIndoors)) sowNow.push(`${s.crop} (indoors)`);
    if (monthIn(nowMonth, s.sowOutdoors)) sowNow.push(`${s.crop} (direct)`);
  }
  if (sowNow.length) { document.getElementById('sownow').hidden = false; document.getElementById('sownow-list').textContent = sowNow.join(', ') + ' · '; }

  // ---- weather (Open-Meteo, no key needed) --------------------------------
  // Past days get their actual rainfall; the next 16 days get probability +
  // expected mm. Recent data is cached for an hour, old months forever
  // (history doesn't change).
  const iso = (d) => d.toISOString().slice(0, 10);
  const todayISO = iso(new Date(Date.now() - new Date().getTimezoneOffset() * 60000));
  const rain = new Map(); // iso date -> { mm, prob?, fc }
  const wxRequested = new Set();
  const WX = `latitude=${PLOT_LOCATION.lat}&longitude=${PLOT_LOCATION.lon}&timezone=auto`;
  const cacheGet = (key, maxAgeMs) => {
    try {
      const raw = localStorage.getItem(key); if (!raw) return null;
      const { t, v } = JSON.parse(raw);
      return maxAgeMs && Date.now() - t > maxAgeMs ? null : v;
    } catch { return null; }
  };
  const cacheSet = (key, v) => { try { localStorage.setItem(key, JSON.stringify({ t: Date.now(), v })); } catch {} };
  function ingest(daily) {
    (daily.time || []).forEach((d, i) => {
      const mm = daily.precipitation_sum?.[i];
      const prob = daily.precipitation_probability_max?.[i];
      if (mm == null && prob == null) return;
      rain.set(d, { mm: mm ?? 0, prob: d > todayISO ? prob : undefined, fc: d > todayISO });
    });
  }
  async function fetchWx(key, url, maxAgeMs) {
    let v = cacheGet(key, maxAgeMs);
    if (!v) {
      const r = await fetch(url); if (!r.ok) throw new Error('wx ' + r.status);
      v = await r.json(); cacheSet(key, v);
    }
    if (v.daily) ingest(v.daily);
  }
  async function loadRecentWx() {
    try {
      await fetchWx('allotment:wx:recent:v1',
        `https://api.open-meteo.com/v1/forecast?${WX}&daily=precipitation_sum,precipitation_probability_max&past_days=92&forecast_days=16`, 3600e3);
      renderWxBanner(); render();
    } catch {} // no weather is fine — the calendar still works
  }
  function loadArchiveWx(y, m) { // months beyond the 92-day recent window
    const start = `${y}-${String(m + 1).padStart(2, '0')}-01`;
    const end = iso(new Date(Date.UTC(y, m + 1, 0)));
    if (end >= iso(new Date(Date.now() - 92 * 86400000)) || start > todayISO) return;
    const key = `allotment:wx:arch:${start}`;
    if (wxRequested.has(key)) return;
    wxRequested.add(key);
    fetchWx(key, `https://archive-api.open-meteo.com/v1/archive?${WX}&start_date=${start}&end_date=${end}&daily=precipitation_sum`)
      .then(() => render()).catch(() => {});
  }
  const RAIN_MIN = 0.3; // below this we call it dry
  const RAIN_PROPER = 2; // mm that actually waters the beds
  const fmtMM = (mm) => (mm >= 10 ? Math.round(mm) : Math.round(mm * 10) / 10) + 'mm';
  function renderWxBanner() {
    const el = document.getElementById('wx');
    // last proper rain (walk back from today)
    const dayISO = (k) => { const d = new Date(today.getTime() + k * 86400000); return new Date(d.getTime() - d.getTimezoneOffset() * 60000).toISOString().slice(0, 10); };
    let since = null, lastMM = 0;
    for (let k = 0; k <= 92; k++) {
      const e = rain.get(dayISO(-k));
      if (e && !e.fc && e.mm >= RAIN_PROPER) { since = k; lastMM = e.mm; break; }
    }
    // next likely rain (walk the forecast)
    let nextIn = null, nextE = null;
    for (let k = 1; k <= 16; k++) {
      const e = rain.get(dayISO(k));
      if (e && (e.mm >= RAIN_PROPER || (e.prob ?? 0) >= 60)) { nextIn = k; nextE = e; break; }
    }
    const fmtDay = (k) => new Date(today.getTime() + k * 86400000).toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
    const bits = [];
    if (since === null) bits.push('No proper rain in the last 3 months');
    else if (since === 0) bits.push(`Raining today (${fmtMM(lastMM)}) — no need to water`);
    else if (since === 1) bits.push(`Rained yesterday (${fmtMM(lastMM)}) — soil should be damp`);
    else bits.push(`No proper rain for ${since} days`);
    if (since !== null && since > 1) {
      bits.push(nextIn !== null
        ? `next likely rain ${fmtDay(nextIn)}${nextE.prob ? ` (${nextE.prob}%)` : ''}`
        : 'none in the 16-day forecast');
      if (since >= 4 && (nextIn === null || nextIn >= 2)) bits.push('💦 worth a watering trip');
    }
    el.textContent = '💧 ' + bits.join(' · ');
    el.hidden = false;
  }

  // ---- render ------------------------------------------------------------
  const grid = document.getElementById('grid');
  const monthList = document.getElementById('month-list');

  function render() {
    const y = view.getFullYear(), m = view.getMonth();
    document.getElementById('month-label').textContent = `${MONTHS[m]} ${y}`;
    loadArchiveWx(y, m); // no-op if cached, in flight, or within the recent window

    const byDay = {};
    for (const e of events) {
      if (!visible(e)) continue;
      const d = new Date(e.date + 'T00:00:00');
      if (d.getFullYear() === y && d.getMonth() === m) (byDay[d.getDate()] ||= []).push(e);
    }

    const startDow = (new Date(y, m, 1).getDay() + 6) % 7; // Monday = 0
    const days = new Date(y, m + 1, 0).getDate();
    grid.replaceChildren();
    for (let i = 0; i < startDow; i++) { const c = document.createElement('div'); c.className = 'cell cell--pad'; grid.append(c); }
    for (let day = 1; day <= days; day++) {
      const cell = document.createElement('div'); cell.className = 'cell';
      const date = new Date(y, m, day);
      if (date.getTime() === today.getTime()) cell.classList.add('is-today');
      const num = document.createElement('span'); num.className = 'cell__num'; num.textContent = String(day); cell.append(num);
      const wx = rain.get(`${y}-${String(m + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`);
      if (wx && (wx.mm >= RAIN_MIN || (wx.prob ?? 0) >= 40)) {
        const r = document.createElement('span');
        r.className = 'raind' + (wx.fc ? ' raind--fc' : '');
        r.textContent = wx.fc
          ? `💧${wx.prob != null ? wx.prob + '%' : ''}${wx.mm >= RAIN_MIN ? ' ' + fmtMM(wx.mm) : ''}`
          : `💧${fmtMM(wx.mm)}`;
        r.title = wx.fc ? 'Rain forecast' : 'It rained';
        cell.append(r);
        if (!wx.fc && wx.mm >= RAIN_PROPER) cell.classList.add('is-wet');
      }
      for (const e of byDay[day] || []) {
        const c = CATS[e.cat] || CATS.job;
        const chip = document.createElement('span'); chip.className = 'chip'; chip.style.setProperty('--c', c.color);
        chip.textContent = (c.emoji ? c.emoji + ' ' : '') + e.title;
        chip.title = `${c.label}: ${e.title}${e.area ? ' — ' + e.area : ''}`;
        cell.append(chip);
      }
      cell.addEventListener('click', () => openDay(y, m, day));
      grid.append(cell);
    }

    // compact list of this month's events
    const items = Object.entries(byDay).sort((a, b) => +a[0] - +b[0]);
    monthList.replaceChildren();
    if (!items.length) { const p = document.createElement('p'); p.className = 'muted'; p.textContent = 'Nothing this month with the current filters.'; monthList.append(p); }
    else for (const [day, evs] of items) for (const e of evs) {
      const row = document.createElement('div'); row.className = 'mrow';
      const dd = document.createElement('span'); dd.className = 'mrow__day'; dd.textContent = `${day} ${MONTHS[m].slice(0, 3)}`;
      const tag = document.createElement('span'); tag.className = 'mrow__tag'; tag.style.setProperty('--c', CATS[e.cat].color); tag.textContent = CATS[e.cat].label;
      const tt = document.createElement('span'); tt.className = 'mrow__title'; tt.textContent = e.title;
      const ar = document.createElement('span'); ar.className = 'mrow__area muted'; ar.textContent = e.area || '';
      row.append(dd, tag, tt, ar); monthList.append(row);
    }
    stamp(grid); stamp(monthList);
  }

  // ---- day popup: everything on one day, full text + add diary entries ----
  const dayDialog = document.getElementById('day-dialog');
  const dayBody = document.getElementById('day-body');
  function openDay(y, m, day) {
    const isoDay = `${y}-${String(m + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
    dayBody.replaceChildren();
    const h = document.createElement('h3');
    h.textContent = new Date(y, m, day).toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
    dayBody.append(h);

    const wx = rain.get(isoDay);
    if (wx && (wx.mm >= RAIN_MIN || (wx.prob ?? 0) >= 20)) {
      const w = document.createElement('p'); w.className = 'day-wx';
      w.textContent = wx.fc
        ? `💧 Rain forecast: ${wx.prob != null ? wx.prob + '% chance' : ''}${wx.mm >= RAIN_MIN ? `, ~${fmtMM(wx.mm)}` : ''}`
        : `💧 It rained: ${fmtMM(wx.mm)}`;
      dayBody.append(w);
    }

    const todays = events.filter((e) => e.date === isoDay);
    if (!todays.length) { const p = document.createElement('p'); p.className = 'muted'; p.textContent = 'Nothing on this day yet.'; dayBody.append(p); }
    for (const e of todays) {
      const c = CATS[e.cat] || CATS.job;
      const row = document.createElement('div'); row.className = 'day-ev';
      const tag = document.createElement('span'); tag.className = 'day-ev__tag'; tag.style.setProperty('--c', c.color); tag.textContent = `${c.emoji || ''} ${c.label}`.trim();
      const body = document.createElement('div'); body.className = 'day-ev__body';
      const tt = document.createElement('strong'); tt.textContent = e.title; body.append(tt);
      if (e.area) { const ar = document.createElement('span'); ar.className = 'muted small'; ar.textContent = e.area; body.append(ar); }
      if (e.detail) { const d = document.createElement('span'); d.className = 'small'; d.textContent = e.detail; body.append(d); }
      const links = document.createElement('span'); links.className = 'day-links';
      if (e.areaId) { const a = document.createElement('a'); a.href = `${SITE_BASE}/#${e.areaId}`; a.textContent = 'open bed →'; links.append(a); }
      if (!e.logId && (e.cat === 'sow' || e.cat === 'plant' || e.cat === 'harvest')) { const a = document.createElement('a'); a.href = `${SITE_BASE}/pipeline`; a.textContent = 'pipeline →'; links.append(a); }
      if (links.childNodes.length) body.append(links);
      row.append(tag, body);
      if (e.logId) {
        const del = document.createElement('button'); del.type = 'button'; del.className = 'day-del'; del.textContent = '✕'; del.title = 'Delete this diary entry';
        del.addEventListener('click', () => { log.entries = log.entries.filter((x) => x.id !== e.logId); saveLog(); buildEvents(); render(); openDay(y, m, day); });
        row.append(del);
      }
      dayBody.append(row);
    }

    // add a diary entry for this day
    const form = document.createElement('div'); form.className = 'day-add';
    const fh = document.createElement('h4'); fh.textContent = '+ Log something for this day'; form.append(fh);
    const cat = document.createElement('select');
    for (const k of LOG_CATS) { const o = document.createElement('option'); o.value = k; o.textContent = `${CATS[k].emoji} ${CATS[k].label}`; cat.append(o); }
    const title = document.createElement('input'); title.type = 'text'; title.placeholder = 'What (optional) — e.g. "Skinned the polytunnel"';
    const areaSel = document.createElement('select');
    areaSel.append(new Option('Whole plot / no bed', ''));
    for (const a of areasData.areas) areaSel.append(new Option(a.name, a.id));
    const notes = document.createElement('input'); notes.type = 'text'; notes.placeholder = 'Notes (optional)';
    const addBtn = document.createElement('button'); addBtn.type = 'button'; addBtn.className = 'ctl ctl--primary'; addBtn.textContent = 'Add';
    addBtn.addEventListener('click', () => {
      log.entries.push({ id: uid('log-'), date: isoDay, category: cat.value, title: title.value.trim() || undefined, areaId: areaSel.value || undefined, notes: notes.value.trim() || undefined });
      saveLog(); buildEvents(); render(); openDay(y, m, day);
    });
    form.append(cat, title, areaSel, notes, addBtn);
    dayBody.append(form);

    const menu = document.createElement('menu'); menu.className = 'day-menu';
    const close = document.createElement('button'); close.type = 'button'; close.className = 'ctl'; close.textContent = 'Close'; close.addEventListener('click', () => dayDialog.close());
    menu.append(close); dayBody.append(menu);
    stamp(dayBody);
    if (!dayDialog.open) dayDialog.showModal();
  }
  dayDialog.addEventListener('click', (e) => { if (e.target === dayDialog) dayDialog.close(); });

  // ---- publish diary entries ----------------------------------------------
  document.getElementById('publish').addEventListener('click', async () => {
    const token = await getToken(); if (!token) return;
    barStatus.textContent = 'Saving…';
    try {
      await commitFiles(token, [{ path: LOG_PATH, text: JSON.stringify(log, null, 2) }], 'Update plot diary');
      logBaseline = JSON.stringify(log); bar.hidden = !logDirty(); barStatus.textContent = '✓ Saved — live in ~1 min.';
    } catch (e) { barStatus.textContent = e.message === 'auth' ? 'Auth failed — check token.' : 'Error: ' + e.message; }
  });
  document.getElementById('discard').addEventListener('click', () => {
    if (!confirm('Discard unsaved diary entries?')) return;
    overlayClear(LOG_KEY); log = structuredClone(logData); saveLog(); buildEvents(); render(); barStatus.textContent = '';
  });
  bar.hidden = !logDirty();

  render();
  loadRecentWx();
</script>

<style>
  .sownow { background: var(--green-100); border: 1px solid color-mix(in srgb, var(--green) 22%, white); border-radius: var(--radius-sm); padding: 0.55rem 0.9rem; margin-bottom: 1.1rem; font-size: 0.9rem; }
  .sownow a { font-weight: 600; text-decoration: none; }

