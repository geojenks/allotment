---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Allotment — Pipeline" active="pipeline" wide={true}>
  <header class="page-head">
    <p class="eyebrow">Seed to plate</p>
    <h1>Pipeline</h1>
    <p>
      Every sowing, from packet to harvest. Dates are predicted from when you <em>actually</em> sowed
      (sow a month late and everything shifts a month) — tap a card to see its story or nudge the dates.
    </p>
  </header>

  <div id="bar" class="savebar" hidden>
    <span class="savebar__label">Unsaved changes</span>
    <button id="publish" class="ctl ctl--primary" type="button">Save to website</button>
    <button id="discard" class="ctl ctl--ghost" type="button">Discard</button>
    <span id="bar-status" class="savebar__status"></span>
  </div>

  <div class="keyrow">
    <span class="key key--ok">on track</span>
    <span class="key key--soon">due soon</span>
    <span class="key key--late">overdue</span>
    <span class="key key--harvest">pick now</span>
    <button id="add-bought" class="ctl" type="button">🛒 Add bought plants</button>
  </div>

  <div id="crops" class="cropstrip"></div>

  <div id="board" class="board">
    <section class="col">
      <h2>🌰 Seed bank <span class="colcount" id="n-seeds"></span></h2>
      <ul id="col-seeds" class="cards"></ul>
    </section>
    <section class="col">
      <h2>🌱 Nursery <span class="colcount" id="n-nursery"></span> <a class="gh-link" href={`${base}/map#home-greenhouse`}>📷 journal</a></h2>
      <ul id="col-nursery" class="cards"></ul>
      <p class="empty" id="e-nursery" hidden>Nothing under glass.</p>
    </section>
    <section class="col">
      <h2>🌍 Growing on <span class="colcount" id="n-ground"></span></h2>
      <ul id="col-ground" class="cards"></ul>
      <p class="empty" id="e-ground" hidden>Nothing growing on yet.</p>
    </section>
    <section class="col">
      <h2>🧺 Harvest <span class="colcount" id="n-harvest"></span></h2>
      <ul id="col-harvest" class="cards"></ul>
      <p class="empty" id="e-harvest" hidden>Nothing ready yet.</p>
    </section>
  </div>

  <dialog id="detail" class="dialog"><form id="detail-form" method="dialog"></form></dialog>
  <dialog id="crop-dialog" class="dialog"><div id="crop-body" class="crop-body"></div></dialog>
</Base>

<script>
  import seedsData from '../data/seeds.json';
  import areasData from '../data/areas.json';
  import { getToken, commitFiles, overlayLoad, overlaySave, overlayClear, uid, todayStr, scopeStamp } from '../lib/datastore';

  const KEY = 'allotment:seeds:v1';
  const PATH = 'src/data/seeds.json';
  const SITE_BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
  const FAMILIES = [
    ['brassica', 'Brassicas'], ['legume', 'Legumes'], ['allium', 'Alliums'],
    ['solanaceae', 'Potato family'], ['apiaceae', 'Umbellifers'], ['cucurbit', 'Cucurbits'],
    ['chenopod', 'Beets & chard'], ['other', 'Other / herb'], ['flower', 'Flowers'],
  ];
  // Generic knowledge for plants bought as plugs (no packet to read).
  const FAM_GUESS = [
    [/cauli|cabbage|savoy|broccoli|psb|kale|sprout|swede|turnip|radish/i, 'brassica'],
    [/pea|bean/i, 'legume'], [/onion|garlic|leek|shallot/i, 'allium'],
    [/potato|tomato|pepper|chilli|aubergine/i, 'solanaceae'],
    [/carrot|parsnip|celeriac|celery|fennel/i, 'apiaceae'],
    [/courgette|squash|pumpkin|cucumber|marrow/i, 'cucurbit'],
    [/beetroot|chard|spinach/i, 'chenopod'], [/flower|dahlia|marigold/i, 'flower'],
  ];
  const guessFam = (name) => { for (const [re, f] of FAM_GUESS) if (re.test(name)) return f; return 'other'; };
  const WEEKS_GUESS = [
    [/psb|purple sprouting/i, 32], [/sprout/i, 22], [/celeriac/i, 20], [/leek/i, 18], [/onion|garlic/i, 16],
    [/cauli|squash|pumpkin/i, 14], [/savoy|cabbage/i, 13], [/broccoli/i, 11], [/tomato/i, 9],
    [/kale|bean|pea/i, 8], [/courgette/i, 7], [/lettuce|salad/i, 5],
  ];
  const guessWeeks = (name) => { for (const [re, w] of WEEKS_GUESS) if (re.test(name)) return w; return 12; };
  const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
  const STAGES = [
    ['sown', 'Sown'], ['germinated', 'Germinated'], ['potted-on', 'Potted on'],
    ['hardening-off', 'Hardening off'], ['planted-out', 'Planted out'], ['failed', 'Failed'],
  ];
  const LOC_LABEL = { greenhouse: 'Greenhouse', polytunnel: 'Polytunnel', nursery: 'Nursery bed', windowsill: 'Windowsill', outdoor: 'Outdoors (direct)' };
  /** Typical weeks from sowing under glass to plant-out, by family (packet `nurseryWeeks` overrides). */
  const NURSERY_WEEKS = { brassica: 6, legume: 3, allium: 9, solanaceae: 8, apiaceae: 5, cucurbit: 4, chenopod: 4, asparagus: 10, other: 6, flower: 6 };

  let data = overlayLoad(KEY, seedsData);
  let baseline = JSON.stringify(seedsData);
  const dirty = () => JSON.stringify(data) !== baseline;

  const areaName = (id) => areasData.areas.find((a) => a.id === id)?.name;
  const seedOf = (s) => data.seeds.find((x) => x.id === s.seedId);
  const nowMonth = new Date().getMonth() + 1;
  const monthIn = (m, w) => (w ? (w.from <= w.to ? m >= w.from && m <= w.to : m >= w.from || m <= w.to) : false);
  const monthsUntil = (w) => { if (!w) return Infinity; for (let d = 0; d <= 11; d++) if (monthIn(((nowMonth - 1 + d) % 12) + 1, w)) return d; return Infinity; };
  const fmt = (d) => new Date(d + 'T00:00:00').toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
  const addDays = (iso, n) => { const d = new Date(iso + 'T00:00:00'); d.setDate(d.getDate() + n); return d.toISOString().slice(0, 10); };
  const daysUntil = (iso) => Math.round((new Date(iso + 'T00:00:00') - new Date(todayStr() + 'T00:00:00')) / 86400000);
  const readyPhrase = (iso) => { const d = new Date(iso + 'T00:00:00'); const p = d.getDate() <= 10 ? 'early' : d.getDate() <= 20 ? 'mid' : 'late'; return `${p} ${MONTHS[d.getMonth()]}`; };
  const cropTitle = (s) => `${s.crop}${s.variety ? ' · ' + s.variety : ''}`;

  // ---- adaptive dates ------------------------------------------------------
  function expPlantOut(s) {
    if (s.expectedPlantOut) return s.expectedPlantOut;
    const weeks = seedOf(s)?.nurseryWeeks ?? NURSERY_WEEKS[s.family] ?? 6;
    return addDays(s.sownDate, weeks * 7);
  }
  function expHarvest(s) {
    if (s.expectedHarvestFrom) return s.expectedHarvestFrom;
    const seed = seedOf(s);
    const sowW = seed?.sowIndoors || seed?.sowOutdoors;
    if (seed?.harvest && sowW) {
      // The packet's own sow→harvest lag, applied to the REAL sow date.
      const lagMonths = (seed.harvest.from - sowW.from + 12) % 12;
      return addDays(s.sownDate, Math.round(lagMonths * 30.44));
    }
    return addDays(s.sownDate, 14 * 7); // no packet info: ~14 weeks
  }

  // ---- columns & status ----------------------------------------------------
  function colOf(s) {
    if (s.stage === 'failed') return null;
    if (s.underGlass && s.stage !== 'planted-out' && !s.noPlantOut) return 'nursery';
    return daysUntil(expHarvest(s)) <= 0 ? 'harvest' : 'ground';
  }
  function statusOf(s) {
    if (colOf(s) === 'nursery') {
      const d = daysUntil(expPlantOut(s));
      if (d < 0) return { cls: 'late', txt: `plant out overdue ${-d}d` };
      if (d <= 7) return { cls: 'soon', txt: d === 0 ? 'plant out today' : `plant out in ${d}d` };
      return { cls: 'ok', txt: `plant out ~${fmt(expPlantOut(s))}` };
    }
    const d = daysUntil(expHarvest(s));
    if (d <= 0) return { cls: 'harvest', txt: 'ready to pick' };
    if (d <= 14) return { cls: 'soon', txt: `ready in ~${d}d` };
    return { cls: 'ok', txt: `ready ~${readyPhrase(expHarvest(s))}` };
  }
  function packetStatus(seed) {
    const inNow = monthIn(nowMonth, seed.sowIndoors), outNow = monthIn(nowMonth, seed.sowOutdoors);
    if (inNow || outNow) {
      const nextM = (nowMonth % 12) + 1;
      const last = !(monthIn(nextM, seed.sowIndoors) || monthIn(nextM, seed.sowOutdoors));
      if (last) return { cls: 'late', txt: 'sow now — last month' };
      return { cls: 'soon', txt: outNow && inNow ? 'sow now (either way)' : outNow ? 'sow direct now' : 'sow indoors now' };
    }
    const d = Math.min(monthsUntil(seed.sowIndoors), monthsUntil(seed.sowOutdoors));
    if (d === Infinity) return { cls: 'ok', txt: '' };
    return { cls: 'ok', txt: `sow from ${MONTHS[(nowMonth - 1 + d) % 12]}` };
  }
  /** "From seed 18 Mar · planted out 2 May · ready ~early July" */
  function storyOf(s) {
    const bits = [`from seed ${fmt(s.sownDate)}`];
    if (s.plantedOutDate) bits.push(`planted out ${fmt(s.plantedOutDate)}${s.destinationAreaId && areaName(s.destinationAreaId) ? ' in ' + areaName(s.destinationAreaId) : ''}`);
    else if (s.underGlass && s.noPlantOut) bits.push(`growing on in the ${(LOC_LABEL[s.location] || s.location).toLowerCase()}`);
    else if (s.underGlass) bits.push(`in the ${(LOC_LABEL[s.location] || s.location).toLowerCase()}, plant out ~${fmt(expPlantOut(s))}`);
    else bits.push(`sown direct${s.destinationAreaId && areaName(s.destinationAreaId) ? ' in ' + areaName(s.destinationAreaId) : ''}`);
    bits.push(daysUntil(expHarvest(s)) <= 0 ? 'ready now' : `ready ~${readyPhrase(expHarvest(s))}`);
    return bits.join(' · ');
  }
  const placeOf = (s) => {
    if (s.stage === 'planted-out') return (s.destinationAreaId && areaName(s.destinationAreaId)) || 'the plot';
    if (s.underGlass) return LOC_LABEL[s.location] || s.location;
    return (s.destinationAreaId && areaName(s.destinationAreaId)) || 'the plot';
  };

  // ---- render ---------------------------------------------------------------
  const board = document.getElementById('board');
  const stamp = scopeStamp(board);
  const bar = document.getElementById('bar');
  const barStatus = document.getElementById('bar-status');
  const detail = document.getElementById('detail');
  const detailForm = document.getElementById('detail-form');
  const cropDialog = document.getElementById('crop-dialog');
  const cropBody = document.getElementById('crop-body');
  const save = () => { overlaySave(KEY, data); updateBar(); };
  const updateBar = () => { bar.hidden = !dirty(); };

  function pill(st) { const p = document.createElement('span'); p.className = 'pill2 pill2--' + st.cls; p.textContent = st.txt; return p; }

  function sowingCard(s) {
    const li = document.createElement('li');
    const st = statusOf(s);
    li.className = 'pcard pcard--' + st.cls;
    const top = document.createElement('div'); top.className = 'pcard__top';
    const h = document.createElement('strong'); h.textContent = s.crop; top.append(h);
    if (s.qty) { const q = document.createElement('span'); q.className = 'qty'; q.textContent = '×' + s.qty; top.append(q); }
    li.append(top);
    if (s.variety) { const v = document.createElement('span'); v.className = 'pcard__var'; v.textContent = s.variety; li.append(v); }
    const meta = document.createElement('span'); meta.className = 'pcard__meta';
    meta.textContent = `${placeOf(s)} · sown ${fmt(s.sownDate)}`;
    li.append(meta);
    if (st.txt) li.append(pill(st));
    li.addEventListener('click', () => openDetail(s));
    return li;
  }

  function packetCard(seed) {
    const li = document.createElement('li');
    const st = packetStatus(seed);
    li.className = 'pcard pcard--' + (st.txt ? st.cls : 'ok');
    const top = document.createElement('div'); top.className = 'pcard__top';
    const h = document.createElement('strong'); h.textContent = seed.crop; top.append(h);
    li.append(top);
    if (seed.variety) { const v = document.createElement('span'); v.className = 'pcard__var'; v.textContent = seed.variety; li.append(v); }
    const growing = data.sowings.filter((x) => x.seedId === seed.id && x.stage !== 'failed' && colOf(x)).length;
    if (growing) { const g = document.createElement('span'); g.className = 'pcard__meta'; g.textContent = `${growing} sowing${growing === 1 ? '' : 's'} on the go →`; li.append(g); }
    if (st.txt) li.append(pill(st));
    li.addEventListener('click', () => { location.href = '../seeds'; });
    return li;
  }

  function render() {
    const cols = { seeds: [], nursery: [], ground: [], harvest: [] };
    for (const seed of data.seeds) if (seed.inStock !== false) cols.seeds.push(seed);
    cols.seeds.sort((a, b) => {
      const rank = (x) => ({ late: 0, soon: 1, ok: 2 })[packetStatus(x).cls] + (packetStatus(x).txt ? 0 : 9);
      return rank(a) - rank(b) || a.crop.localeCompare(b.crop);
    });
    for (const s of data.sowings) { const c = colOf(s); if (c) cols[c].push(s); }
    cols.nursery.sort((a, b) => expPlantOut(a).localeCompare(expPlantOut(b)));
    cols.ground.sort((a, b) => expHarvest(a).localeCompare(expHarvest(b)));
    cols.harvest.sort((a, b) => expHarvest(a).localeCompare(expHarvest(b)));

    for (const [key, list] of Object.entries(cols)) {
      const ul = document.getElementById('col-' + key);
      ul.replaceChildren();
      for (const item of list) ul.append(key === 'seeds' ? packetCard(item) : sowingCard(item));
      document.getElementById('n-' + key).textContent = list.length ? String(list.length) : '';
      const empty = document.getElementById('e-' + key);
      if (empty) empty.hidden = list.length > 0;
    }
    renderCrops();
    stamp(board);
    updateBar();
  }

  // ---- per-crop aggregate ("5 in greenhouse, 4 in Bed 2") -------------------
  function renderCrops() {
    const strip = document.getElementById('crops');
    strip.replaceChildren();
    const byCrop = new Map();
    for (const s of data.sowings) { if (!colOf(s)) continue; (byCrop.get(s.crop) || byCrop.set(s.crop, []).get(s.crop)).push(s); }
    for (const [crop, list] of [...byCrop.entries()].sort((a, b) => a[0].localeCompare(b[0]))) {
      const chip = document.createElement('button'); chip.type = 'button'; chip.className = 'cropchip';
      const total = list.reduce((n, s) => n + (s.qty || 1), 0);
      chip.textContent = `${crop} ×${total}`;
      chip.addEventListener('click', () => openCrop(crop, list));
      strip.append(chip);
    }
    stamp(strip);
  }
  function openCrop(crop, list) {
    cropBody.replaceChildren();
    const h = document.createElement('h3'); h.textContent = crop; cropBody.append(h);
    const byPlace = new Map();
    for (const s of list) byPlace.set(placeOf(s), (byPlace.get(placeOf(s)) || 0) + (s.qty || 1));
    const sum = document.createElement('p'); sum.className = 'crop-sum';
    sum.textContent = [...byPlace.entries()].map(([p, n]) => `${n} in ${p}`).join(' · ');
    cropBody.append(sum);
    const ul = document.createElement('ul'); ul.className = 'crop-lines';
    for (const s of list) {
      const li = document.createElement('li');
      const b = document.createElement('button'); b.type = 'button'; b.className = 'crop-line';
      b.textContent = `${cropTitle(s)}${s.qty ? ' ×' + s.qty : ''} — ${storyOf(s)}`;
      b.addEventListener('click', () => { cropDialog.close(); openDetail(s); });
      li.append(b); ul.append(li);
    }
    cropBody.append(ul);
    const menu = document.createElement('menu'); menu.className = 'dialog__menu';
    const close = document.createElement('button'); close.className = 'ctl'; close.textContent = 'Close'; close.addEventListener('click', () => cropDialog.close());
    menu.append(close); cropBody.append(menu);
    stamp(cropBody); cropDialog.showModal();
  }

  // ---- sowing detail: the story + editable dates ----------------------------
  function field(label, node, hint) {
    const w = document.createElement('label'); w.className = 'field';
    const s = document.createElement('span'); s.textContent = label; w.append(s, node);
    if (hint) { const h = document.createElement('em'); h.className = 'field__hint'; h.textContent = hint; w.append(h); }
    return w;
  }
  function openDetail(s) {
    detailForm.replaceChildren();
    const h = document.createElement('h3'); h.textContent = cropTitle(s); detailForm.append(h);
    const story = document.createElement('p'); story.className = 'story'; story.textContent = storyOf(s).replace(/^f/, 'F') + '.'; detailForm.append(story);

    // Progress photos: shots of wherever this sowing currently lives — its bed
    // once planted out (or direct-sown), the Home greenhouse while in the nursery.
    const inNursery = s.underGlass && s.stage !== 'planted-out';
    const photoAreaId = inNursery ? 'home-greenhouse' : s.destinationAreaId;
    const since = inNursery ? s.sownDate : (s.plantedOutDate || (!s.underGlass ? s.sownDate : null));
    if (photoAreaId) {
      const area = areasData.areas.find((a) => a.id === photoAreaId);
      const shots = area && since
        ? (area.events || []).filter((e) => e.kind === 'photo' && e.photo && e.date >= since).sort((a, b) => a.date.localeCompare(b.date))
        : [];
      const prog = document.createElement('div'); prog.className = 'progress';
      if (shots.length) {
        const row = document.createElement('div'); row.className = 'progress__row';
        for (const ev of shots.slice(-6)) {
          const a = document.createElement('a'); a.href = `${SITE_BASE}/map#${photoAreaId}`;
          const img = document.createElement('img'); img.src = `${SITE_BASE}/${ev.photo.src}`; img.alt = ev.date; img.loading = 'lazy'; img.title = ev.date;
          a.append(img); row.append(a);
        }
        prog.append(row);
      }
      const place = inNursery ? 'the greenhouse journal' : (areaName(photoAreaId) || 'the bed');
      const link = document.createElement('a'); link.className = 'progress__link'; link.href = `${SITE_BASE}/map#${photoAreaId}`;
      link.textContent = shots.length ? `See progress in ${place} →` : `Open ${place} (no photos in this window yet) →`;
      prog.append(link);
      detailForm.append(prog);
    }

    const sown = document.createElement('input'); sown.type = 'date'; sown.value = s.sownDate; sown.max = todayStr();
    sown.addEventListener('change', () => { if (sown.value) { s.sownDate = sown.value; save(); } });
    detailForm.append(field('Sown', sown));

    const qty = document.createElement('input'); qty.type = 'number'; qty.min = '1'; qty.step = '1'; qty.inputMode = 'numeric'; qty.value = s.qty || '';
    qty.addEventListener('change', () => { s.qty = qty.value ? Math.max(1, Math.round(+qty.value)) : undefined; save(); });
    detailForm.append(field('How many', qty));

    const stage = document.createElement('select');
    for (const [v, l] of STAGES) { const o = document.createElement('option'); o.value = v; o.textContent = l; if (s.stage === v) o.selected = true; stage.append(o); }
    stage.addEventListener('change', () => {
      s.stage = stage.value;
      if (s.stage === 'planted-out' && !s.plantedOutDate) s.plantedOutDate = todayStr();
      if (s.stage !== 'planted-out') s.plantedOutDate = undefined;
      save(); openDetail(s); // re-render the form: fields depend on stage
    });
    detailForm.append(field('Stage', stage));

    if (s.underGlass && s.stage !== 'planted-out') {
      const stayRow = document.createElement('label'); stayRow.className = 'field field--check';
      const stay = document.createElement('input'); stay.type = 'checkbox'; stay.checked = !!s.noPlantOut;
      stay.addEventListener('change', () => { s.noPlantOut = stay.checked || undefined; save(); openDetail(s); });
      const stayTxt = document.createElement('span'); stayTxt.textContent = 'Stays under cover — fruits where it is (no plant-out)';
      stayRow.append(stay, stayTxt); detailForm.append(stayRow);
      if (!s.noPlantOut) {
        const po = document.createElement('input'); po.type = 'date'; po.value = expPlantOut(s);
        po.addEventListener('change', () => { s.expectedPlantOut = po.value || undefined; save(); });
        detailForm.append(field('Expected plant-out', po, s.expectedPlantOut ? 'pinned by you' : 'predicted from your sow date — edit to pin'));
      }
    }
    if (s.stage === 'planted-out') {
      const pod = document.createElement('input'); pod.type = 'date'; pod.value = s.plantedOutDate || ''; pod.max = todayStr();
      pod.addEventListener('change', () => { s.plantedOutDate = pod.value || undefined; save(); });
      detailForm.append(field('Planted out', pod));
    }
    const dest = document.createElement('select');
    const dn = document.createElement('option'); dn.value = ''; dn.textContent = '— no bed yet —'; dest.append(dn);
    for (const a of areasData.areas) { if (a.id === "home-greenhouse") continue; const o = document.createElement("option"); o.value = a.id; o.textContent = a.name; if (s.destinationAreaId === a.id) o.selected = true; dest.append(o); }
    dest.addEventListener('change', () => { s.destinationAreaId = dest.value || undefined; save(); });
    detailForm.append(field('Bed', dest));

    const eh = document.createElement('input'); eh.type = 'date'; eh.value = expHarvest(s);
    eh.addEventListener('change', () => { s.expectedHarvestFrom = eh.value || undefined; save(); });
    detailForm.append(field('Expected first harvest', eh, s.expectedHarvestFrom ? 'pinned by you' : 'predicted from your sow date — edit to pin'));

    const notes = document.createElement('textarea'); notes.rows = 2; notes.value = s.notes || '';
    notes.addEventListener('change', () => { s.notes = notes.value.trim() || undefined; save(); });
    detailForm.append(field('Notes', notes));

    const menu = document.createElement('div'); menu.className = 'dialog__menu';
    const del = document.createElement('button'); del.type = 'button'; del.className = 'danger'; del.textContent = 'Delete';
    del.addEventListener('click', () => { if (!confirm('Delete this sowing?')) return; data.sowings = data.sowings.filter((x) => x.id !== s.id); save(); detail.close(); render(); });
    const done = document.createElement('button'); done.type = 'submit'; done.className = 'ctl ctl--primary'; done.textContent = 'Done';
    menu.append(del, done); detailForm.append(menu);
    detailForm.onsubmit = () => render();
    stamp(detailForm); if (!detail.open) detail.showModal();
  }

  // ---- bought plants: plugs / started plants with no packet ----------------
  function openBought() {
    detailForm.replaceChildren();
    const h = document.createElement('h3'); h.textContent = '🛒 Add bought plants'; detailForm.append(h);
    const intro = document.createElement('p'); intro.className = 'story';
    intro.textContent = 'For plugs or started plants (no seed packet). Family and harvest timing are guessed from the name — check them before saving.';
    detailForm.append(intro);
    const crop = document.createElement('input'); crop.type = 'text'; crop.placeholder = 'e.g. Cauliflower'; detailForm.append(field('Plant', crop));
    const variety = document.createElement('input'); variety.type = 'text'; detailForm.append(field('Variety (optional)', variety));
    const qty = document.createElement('input'); qty.type = 'number'; qty.min = '1'; qty.inputMode = 'numeric'; qty.placeholder = 'e.g. 6'; detailForm.append(field('How many', qty));
    const fam = document.createElement('select');
    for (const [v, l] of FAMILIES) { const o = document.createElement('option'); o.value = v; o.textContent = l; fam.append(o); }
    let famTouched = false;
    fam.addEventListener('change', () => { famTouched = true; });
    crop.addEventListener('input', () => { if (!famTouched) fam.value = guessFam(crop.value); });
    detailForm.append(field('Family', fam, 'guessed from the name — used for rotation and defaults'));
    const date = document.createElement('input'); date.type = 'date'; date.value = todayStr(); date.max = todayStr(); detailForm.append(field('Date planted', date));
    const where = document.createElement('select');
    where.append(new Option('Straight into a bed', 'bed'), new Option('Nursery / greenhouse first', 'nursery'));
    detailForm.append(field('Where did they go?', where));
    const dest = document.createElement('select');
    dest.append(new Option('— choose bed —', ''));
    for (const a of areasData.areas) if (a.id !== "home-greenhouse") dest.append(new Option(a.name, a.id));
    detailForm.append(field('Bed', dest));

    const menu = document.createElement('div'); menu.className = 'dialog__menu';
    const cancel = document.createElement('button'); cancel.type = 'button'; cancel.className = 'ctl ctl--ghost'; cancel.textContent = 'Cancel'; cancel.addEventListener('click', () => detail.close());
    const ok = document.createElement('button'); ok.type = 'submit'; ok.className = 'ctl ctl--primary'; ok.textContent = 'Add';
    menu.append(cancel, ok); detailForm.append(menu);
    detailForm.onsubmit = () => {
      const name = crop.value.trim(); if (!name) return;
      const d = date.value || todayStr();
      const direct = where.value === 'bed';
      data.sowings.push({
        id: uid('sow-'), crop: name, variety: variety.value.trim() || undefined, family: fam.value,
        sownDate: d, location: direct ? 'outdoor' : 'greenhouse', underGlass: !direct,
        stage: direct ? 'planted-out' : 'potted-on', plantedOutDate: direct ? d : undefined,
        qty: qty.value ? Math.max(1, Math.round(+qty.value)) : undefined,
        destinationAreaId: dest.value || undefined,
        expectedHarvestFrom: addDays(d, guessWeeks(name) * 7), // generic guess, pinned — edit on the card
        notes: 'Bought as plants',
      });
      save(); render();
    };
    stamp(detailForm); if (!detail.open) detail.showModal();
  }
  document.getElementById('add-bought').addEventListener('click', openBought);

  // ---- publish ----------------------------------------------------------------
  document.getElementById('publish').addEventListener('click', async () => {
    const token = await getToken(); if (!token) return;
    barStatus.textContent = 'Saving…';
    try { await commitFiles(token, [{ path: PATH, text: JSON.stringify(data, null, 2) }], 'Update pipeline / sowings'); baseline = JSON.stringify(data); updateBar(); barStatus.textContent = '✓ Saved — live in ~1 min.'; }
    catch (e) { barStatus.textContent = e.message === 'auth' ? 'Auth failed — check token.' : 'Error: ' + e.message; }
  });
  document.getElementById('discard').addEventListener('click', () => {
    if (!confirm('Discard local changes and revert to the saved version?')) return;
    overlayClear(KEY); data = structuredClone(seedsData); render(); barStatus.textContent = '';
  });
  for (const d of [detail, cropDialog]) d.addEventListener('click', (e) => { if (e.target === d) { const r = d.getBoundingClientRect(); if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) { d.close(); if (d === detail) render(); } } });
  detail.addEventListener('close', () => render());

  render();
</script>

