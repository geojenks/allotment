    }
    const nb = document.createElement('button'); nb.type = 'button'; nb.className = 'crop-btn crop-btn--new'; nb.title = 'Add a new plant type';
    const ni = document.createElement('span'); ni.className = 'crop-btn__icon'; ni.textContent = '＋';
    const nl = document.createElement('span'); nl.className = 'crop-btn__label'; nl.textContent = 'New plant';
    nb.append(ni, nl);
    nb.addEventListener('click', () => {
      const name = (prompt('Name of the new plant (e.g. "Leek"):') || '').trim();
      if (!name) return;
      if (!cropIcons[name]) { cropIcons[name] = guessIcon(name); save(); }
      renderPalette();
      const btn = [...palette.querySelectorAll('.crop-btn')].find((x) => x.querySelector('.crop-btn__label')?.textContent === name);
      armCrop(name, btn);
    });
    palette.append(nb);
    SCOPE(palette);
  }
  renderPalette();

  // map controls
  const centerFocal = () => ({ x: vb.x + vb.w / 2, y: vb.y + vb.h / 2 });
  document.getElementById('zin').addEventListener('click', () => { cancelAnimationFrame(raf); readVB(); const f = centerFocal(); applyZoom(vb, vb.w * 0.7, f.x, f.y); });
  document.getElementById('zout').addEventListener('click', () => { cancelAnimationFrame(raf); readVB(); const f = centerFocal(); applyZoom(vb, vb.w * 1.43, f.x, f.y); });
  document.getElementById('zreset').addEventListener('click', () => {
    focusedAreaId = null; setTool('select'); setVB(fitBounds(PLOT, 1), true); refreshChrome(); // whole plot
  });
  document.getElementById('fs').addEventListener('click', () => {
    const on = mapCard.classList.toggle('map-card--full');
    document.body.classList.toggle('plot-fs', on);
    requestAnimationFrame(() => requestAnimationFrame(relayout));
  });

  // ---- save actions ------------------------------------------------------
  const buildJSON = () => JSON.stringify({ ...plotData, areas, markers, cropIcons }, null, 2);
  function updateSaveState() { const d = isDirty(); saveStateEl.hidden = !d; avSave.hidden = !d; if (d) saveLabel.textContent = 'Unsaved to site'; }
  document.getElementById('copy-json').addEventListener('click', async () => { document.getElementById('export-text').value = buildJSON(); try { await navigator.clipboard.writeText(buildJSON()); } catch {} exportDialog.showModal(); });
  document.getElementById('download-json').addEventListener('click', () => { const a = document.createElement('a'); a.href = URL.createObjectURL(new Blob([buildJSON()], { type: 'application/json' })); a.download = 'areas.json'; a.click(); URL.revokeObjectURL(a.href); });
  document.getElementById('discard').addEventListener('click', () => { if (!confirm('Discard local changes on this device and revert to the saved site version?')) return; localStorage.removeItem(STORE_KEY); const fresh = JSON.parse(baselineJSON); areas = fresh.areas; markers = fresh.markers; cropIcons = fresh.cropIcons || {}; clearSelection(); renderAreas(); renderMarkers(); refreshSelection(); updateSaveState(); });
  const setWeb = (m) => { webStatus.textContent = m || ''; };
  const GH_API = `https://api.github.com/repos/${repo.owner}/${repo.name}`;
  async function getToken() {
    let t = localStorage.getItem(TOKEN_KEY);
    if (!t) { t = prompt('Paste a GitHub token to publish.\n\nCreate a fine-grained token (github.com → Settings → Developer settings → Fine-grained tokens) limited to the "allotment" repo, with Contents: Read and write. Stored only on this device.'); if (!t) return null; localStorage.setItem(TOKEN_KEY, t.trim()); }
    return t.trim();
  }
  // One atomic commit for any number of files (text or base64 binary), via the git data API.
  async function commitFiles(token, files, message) {
    const headers = { Authorization: `Bearer ${token}`, Accept: 'application/vnd.github+json' };
    const refRes = await fetch(`${GH_API}/git/ref/heads/${repo.branch}`, { headers });
    if (refRes.status === 401) { localStorage.removeItem(TOKEN_KEY); throw new Error('auth'); }
    if (!refRes.ok) throw new Error('ref ' + refRes.status);
    const commitSha = (await refRes.json()).object.sha;
    const baseCommit = await (await fetch(`${GH_API}/git/commits/${commitSha}`, { headers })).json();
    const tree = [];
    for (const f of files) {
      if (f.base64 != null) {
        const br = await fetch(`${GH_API}/git/blobs`, { method: 'POST', headers, body: JSON.stringify({ content: f.base64, encoding: 'base64' }) });
        if (!br.ok) throw new Error('blob ' + br.status);
        tree.push({ path: f.path, mode: '100644', type: 'blob', sha: (await br.json()).sha });
      } else tree.push({ path: f.path, mode: '100644', type: 'blob', content: f.text });
    }
    const nt = await (await fetch(`${GH_API}/git/trees`, { method: 'POST', headers, body: JSON.stringify({ base_tree: baseCommit.tree.sha, tree }) })).json();
    const nc = await (await fetch(`${GH_API}/git/commits`, { method: 'POST', headers, body: JSON.stringify({ message, tree: nt.sha, parents: [commitSha] }) })).json();
    const upd = await fetch(`${GH_API}/git/refs/heads/${repo.branch}`, { method: 'PATCH', headers, body: JSON.stringify({ sha: nc.sha }) });
    if (upd.status === 401 || upd.status === 403) { localStorage.removeItem(TOKEN_KEY); throw new Error('auth'); }
    if (!upd.ok) throw new Error('ref-update ' + upd.status);
  }
  document.getElementById('save-web').addEventListener('click', async () => {
    const token = await getToken(); if (!token) return;
    setWeb('Saving…');
    try { await commitFiles(token, [{ path: repo.path, text: buildJSON() }], 'Update plot from web editor'); baselineJSON = JSON.stringify({ areas, markers, cropIcons }); updateSaveState(); setWeb('✓ Saved — live in ~1 min.'); }
    catch (e) { setWeb(e.message === 'auth' ? 'Auth failed — check token, tap again.' : 'Error: ' + e.message); }
  });

  // ---- photos: compress in-browser + commit -----------------------------
  const transientPhotos = new Map(); // event id -> object URL (instant preview before deploy)
  const blobToB64 = (blob) => new Promise((res, rej) => { const r = new FileReader(); r.onload = () => res(String(r.result).split(',')[1]); r.onerror = rej; r.readAsDataURL(blob); });
  function compress(file, max = 1280, q = 0.82) {
    return new Promise((res, rej) => {
      const url = URL.createObjectURL(file); const img = new Image();
      img.onload = () => {
        let w = img.naturalWidth, h = img.naturalHeight; const s = Math.min(1, max / Math.max(w, h));
        w = Math.round(w * s); h = Math.round(h * s);
        const c = document.createElement('canvas'); c.width = w; c.height = h; c.getContext('2d').drawImage(img, 0, 0, w, h);
        c.toBlob(async (blob) => { URL.revokeObjectURL(url); if (!blob) return rej(new Error('encode')); res({ blob, base64: await blobToB64(blob), w, h }); }, 'image/jpeg', q);
      };
      img.onerror = () => { URL.revokeObjectURL(url); rej(new Error('load')); }; img.src = url;
    });
  }
  async function addPhotos(area, fileList, dateStr, statusEl) {
    const token = await getToken(); if (!token) return;
    const files = [], newEvents = [];
    if (statusEl) statusEl.textContent = 'Processing…';
    try {
      for (const file of fileList) {
        if (!file.type.startsWith('image/')) continue;
        const { blob, base64, w, h } = await compress(file);
        const id = uid('ph-'); const src = `photos/${area.id}/${dateStr}-${id}.jpg`;
        files.push({ path: `public/${src}`, base64 });
        const ev = { id, date: dateStr, kind: 'photo', photo: { src, w, h } };
        newEvents.push(ev); transientPhotos.set(id, URL.createObjectURL(blob));
      }
      if (!newEvents.length) { if (statusEl) statusEl.textContent = 'No images found.'; return; }
      area.events = area.events || []; area.events.push(...newEvents);
      files.push({ path: repo.path, text: buildJSON() });
      if (statusEl) statusEl.textContent = `Uploading ${newEvents.length}…`;
      await commitFiles(token, files, `Add ${newEvents.length} photo(s) to ${area.name}`);
      baselineJSON = JSON.stringify({ areas, markers, cropIcons }); save(); updateSaveState();
      if (statusEl) statusEl.textContent = '✓ Saved — live in ~1 min.';
      renderInfo();
    } catch (e) {
      for (const ev of newEvents) { const i = area.events.indexOf(ev); if (i >= 0) area.events.splice(i, 1); transientPhotos.delete(ev.id); }
      if (statusEl) statusEl.textContent = e.message === 'auth' ? 'Auth failed — check token.' : 'Upload failed: ' + e.message;
    }
  }

  // ---- per-area journal (date scrubber + photos + events) ----------------
  const todayStr = () => new Date().toISOString().slice(0, 10);
  const fmtDate = (d) => new Date(d + 'T00:00:00').toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
  const daysBetween = (a, b) => Math.round((new Date(b + 'T00:00:00') - new Date(a + 'T00:00:00')) / 86400000);
  const photoSrc = (ev) => transientPhotos.get(ev.id) || `${base}/${ev.photo.src}`;
  function buildJournal(area) {
    const wrap = document.createElement('div'); wrap.className = 'journal';
    const hh = document.createElement('h3'); hh.textContent = 'Timeline'; wrap.append(hh);
    const events = (area.events || []).slice().sort((a, b) => a.date.localeCompare(b.date));
    const photos = events.filter((e) => e.kind === 'photo' && e.photo);
    const today = todayStr();
    const start = area.created || events[0]?.date || today;
    const span = Math.max(1, daysBetween(start, today));

    const viewer = document.createElement('div'); viewer.className = 'viewer';
    const imgEl = document.createElement('img'); imgEl.className = 'viewer__img'; imgEl.alt = area.name; imgEl.loading = 'lazy';
    const cap = document.createElement('span'); cap.className = 'viewer__cap';
    const empty = document.createElement('div'); empty.className = 'viewer__empty'; empty.textContent = 'No photos yet';
    viewer.append(imgEl, cap, empty); wrap.append(viewer);

    const scrub = document.createElement('div'); scrub.className = 'scrub';
    const ticks = document.createElement('div'); ticks.className = 'scrub__ticks';
    for (const p of photos) { const t = document.createElement('span'); t.className = 'scrub__tick'; t.style.left = (daysBetween(start, p.date) / span) * 100 + '%'; t.title = fmtDate(p.date); ticks.append(t); }
    const range = document.createElement('input'); range.type = 'range'; range.min = '0'; range.max = String(span); range.value = String(span); range.className = 'scrub__range'; range.setAttribute('aria-label', 'Timeline date');
    const dlabel = document.createElement('div'); dlabel.className = 'scrub__date';
    scrub.append(ticks, range, dlabel); wrap.append(scrub);
    if (!photos.length) scrub.classList.add('is-hidden');

    const selDateFor = (v) => { const d = new Date(start + 'T00:00:00'); d.setDate(d.getDate() + Number(v)); return d.toISOString().slice(0, 10); };
    function update() {
      const sel = selDateFor(range.value); dlabel.textContent = fmtDate(sel);
      let latest = null; for (const p of photos) { if (p.date <= sel) latest = p; else break; }
      if (latest) {
        viewer.classList.remove('is-empty');
        imgEl.src = photoSrc(latest);
        const age = daysBetween(latest.date, sel);
        cap.textContent = age <= 0 ? `photo from ${fmtDate(latest.date)}` : `${age}-day-old photo · ${fmtDate(latest.date)}`;
        cap.hidden = false;
      } else { viewer.classList.add('is-empty'); imgEl.removeAttribute('src'); cap.hidden = true; }
    }
    range.addEventListener('input', update); update();

    const tools = document.createElement('div'); tools.className = 'journal__tools';
    // No `capture` attribute: lets the phone offer Camera *or* Photo Library (needed for back-dating older shots).
    const fileInput = document.createElement('input'); fileInput.type = 'file'; fileInput.accept = 'image/*'; fileInput.multiple = true; fileInput.style.display = 'none';
    const dateRow = document.createElement('label'); dateRow.className = 'journal__daterow';
    const dateLab = document.createElement('span'); dateLab.textContent = '📅 Adding for';
    const dateInput = document.createElement('input'); dateInput.type = 'date'; dateInput.value = today; dateInput.max = today; dateInput.className = 'journal__date';
    const dateAgo = document.createElement('em');
    const syncAgo = () => { const d = daysBetween(dateInput.value || today, today); dateAgo.textContent = d <= 0 ? '(today)' : d === 1 ? '(yesterday)' : `(${d} days ago)`; };
    dateInput.addEventListener('change', syncAgo); syncAgo();
    dateRow.append(dateLab, dateInput, dateAgo);
    const addBtn = document.createElement('button'); addBtn.type = 'button'; addBtn.className = 'ctl ctl--primary'; addBtn.textContent = '📷 Add photo';
    const noteBtn = document.createElement('button'); noteBtn.type = 'button'; noteBtn.className = 'ctl'; noteBtn.textContent = '✎ Note';
    const status = document.createElement('span'); status.className = 'journal__status';
    addBtn.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => { if (fileInput.files?.length) addPhotos(area, fileInput.files, dateInput.value || today, status); fileInput.value = ''; });
    noteBtn.addEventListener('click', () => { const txt = prompt(`Note for ${fmtDate(dateInput.value || today)}:`); if (!txt) return; area.events = area.events || []; area.events.push({ id: uid('n-'), date: dateInput.value || today, kind: 'note', text: txt }); save(); renderInfo(); });
    tools.append(dateRow, addBtn, noteBtn, fileInput, status); wrap.append(tools);

    if (events.length) {
      const ul = document.createElement('ul'); ul.className = 'timeline';
      for (const e of events.slice().reverse()) {
        const li = document.createElement('li');
        const dot = document.createElement('span'); dot.className = 'timeline__dot' + (e.kind === 'photo' ? ' is-photo' : ''); li.append(dot);
        if (e.kind === 'photo' && e.photo) {
          const th = document.createElement('img'); th.className = 'timeline__thumb'; th.src = photoSrc(e); th.alt = ''; th.loading = 'lazy'; li.append(th);
        }
        const body = document.createElement('div'); body.className = 'timeline__body';
        const dt = document.createElement('span'); dt.className = 'timeline__date'; dt.textContent = fmtDate(e.date); body.append(dt);
        const tx = document.createElement('span'); tx.className = 'timeline__txt'; tx.textContent = e.kind === 'photo' ? '📷 Photo' : (e.text || '');
        body.append(tx); li.append(body);

        const acts = document.createElement('div'); acts.className = 'timeline__acts';
        {
          const ed = document.createElement('button'); ed.type = 'button'; ed.className = 'tl-act'; ed.title = 'Change date'; ed.textContent = '📅';
          ed.addEventListener('click', () => {
            const di = document.createElement('input'); di.type = 'date'; di.value = e.date; di.max = todayStr(); di.className = 'tl-sel';
            di.addEventListener('change', () => { if (!di.value) return; e.date = di.value; save(); renderInfo(); });
            acts.replaceChildren(di); di.focus();
          });
          acts.append(ed);
        }
        if (e.kind === 'photo') {
          const mv = document.createElement('button'); mv.type = 'button'; mv.className = 'tl-act'; mv.textContent = '⇄ Move';
          mv.addEventListener('click', () => {
            const sel = document.createElement('select'); sel.className = 'tl-sel';
            const d0 = document.createElement('option'); d0.value = ''; d0.textContent = 'Move to bed…'; sel.append(d0);
            for (const a of areas) { if (a.id === area.id) continue; const o = document.createElement('option'); o.value = a.id; o.textContent = a.name; sel.append(o); }
            sel.addEventListener('change', () => {
              const t = areas.find((a) => a.id === sel.value); if (!t) return;
              const i = area.events.indexOf(e); if (i >= 0) area.events.splice(i, 1);
              t.events = t.events || []; t.events.push(e);
              save(); updatePlantCounts(); renderInfo();
            });
            acts.replaceChildren(sel); sel.focus();
          });
          acts.append(mv);
        }
        const del = document.createElement('button'); del.type = 'button'; del.className = 'tl-act'; del.title = 'Delete entry'; del.textContent = '✕';
        del.addEventListener('click', () => { if (!confirm('Delete this timeline entry?')) return; const i = area.events.indexOf(e); if (i >= 0) area.events.splice(i, 1); save(); updatePlantCounts(); renderInfo(); });
        acts.append(del); li.append(acts);
        ul.append(li);
      }
      wrap.append(ul);
    }
    return wrap;
  }

  // ---- legend + init -----------------------------------------------------
  const legendList = document.getElementById('legend-list');
  for (const [, m] of Object.entries(TYPE_META)) { const li = document.createElement('li'); const sw = document.createElement('span'); sw.className = 'swatch'; sw.style.background = m.color; li.append(sw, document.createTextNode(m.label)); legendList.append(li); }

  // off-plot card (home greenhouse)
  {
    const gh = areas.find((a) => a.id === 'home-greenhouse');
    const wrap = document.getElementById('offplot');
    if (gh && wrap) {
      wrap.hidden = false;
      const photos = (gh.events || []).filter((e) => e.kind === 'photo' && e.photo).sort((a, b) => a.date.localeCompare(b.date));
      document.getElementById('gh-meta').textContent = photos.length
        ? `${photos.length} photo${photos.length === 1 ? '' : 's'} · tap to open the journal`
        : 'tap to open the journal';
      if (photos.length) { const t = document.getElementById('gh-thumb'); t.src = `${base}/${photos[photos.length - 1].photo.src}`; t.hidden = false; }
      document.getElementById('gh-card').addEventListener('click', () => openOverlay('home-greenhouse'));
    }
  }

  renderAreas(); renderMarkers(); refreshSelection(); refreshChrome(); renderInfo(); updateSaveState();
  // Deep link: #<area-id> selects that area on load.
  const hashId = decodeURIComponent(location.hash.replace(/^#/, ''));
  if (hashId && areas.some((a) => a.id === hashId)) { history.replaceState({}, '', location.pathname + location.search); history.pushState({ area: hashId }, '', '#' + hashId); showOverlay(hashId); }
  relayout();
  let ro;
  if (window.ResizeObserver) { ro = new ResizeObserver(() => relayout()); ro.observe(svg); }
  window.addEventListener('resize', () => relayout());
</script>

<style>
  .plot { display: flex; flex-direction: column; gap: 0.9rem; }
  .plot__bar { display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem; }

  .modes { display: inline-flex; border: 1px solid var(--line); border-radius: 999px; overflow: hidden; background: var(--panel); box-shadow: var(--shadow-sm); }
  .mode { border: 0; background: transparent; padding: 0.42rem 1rem; font: inherit; font-weight: 600; cursor: pointer; color: var(--muted); }
  .mode.is-active { background: var(--green); color: #fff; }

  .edit-tools { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }

  .ctl { font: inherit; font-weight: 600; cursor: pointer; border: 1px solid var(--line-strong); background: var(--panel); color: var(--ink); padding: 0.4rem 0.8rem; border-radius: var(--radius-sm); box-shadow: var(--shadow-sm); }
  .ctl:hover { border-color: var(--green); }
  .ctl--primary { background: var(--green); color: #fff; border-color: var(--green); }
  .ctl--primary:hover { background: var(--green-700); }
  .ctl--ghost { color: var(--muted); box-shadow: none; }
  .danger { font: inherit; font-weight: 600; cursor: pointer; border: 1px solid #e3b8b0; color: #a23b2b; background: var(--panel); padding: 0.45rem 0.8rem; border-radius: var(--radius-sm); margin-top: 0.7rem; }
  #zoom-btn { background: var(--green-100); border-color: color-mix(in srgb, var(--green) 35%, white); color: var(--green-700); }

  .palette { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .icon-btn { padding: 0.25rem 0.42rem; font-size: 1.15rem; line-height: 1; border-radius: 8px; border: 1px solid var(--line-strong); background: var(--panel); cursor: pointer; }
  .icon-btn.is-active { border-color: var(--green); background: var(--green-100); }

  /* planting mode: palette docked over the bottom of the map */
  .plant-bar { position: absolute; left: 0.6rem; right: 0.6rem; bottom: max(0.6rem, env(safe-area-inset-bottom)); z-index: 6; display: flex; align-items: center; gap: 0.5rem; background: color-mix(in srgb, var(--panel) 94%, transparent); backdrop-filter: blur(6px); border: 1px solid var(--line); border-radius: var(--radius); padding: 0.45rem 0.55rem; box-shadow: var(--shadow); }
  .plant-bar .palette { flex: 1; flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; padding: 2px; }
  .plant-bar .palette::-webkit-scrollbar { display: none; }
  .plant-bar .ctl { flex-shrink: 0; }
  .crop-btn { display: flex; flex-direction: column; align-items: center; gap: 0; flex-shrink: 0; cursor: pointer; border: 1px solid var(--line-strong); background: var(--panel); border-radius: 10px; padding: 0.25rem 0.4rem 0.2rem; min-width: 3.2rem; max-width: 4.4rem; }
  .crop-btn__icon { font-size: 1.35rem; line-height: 1.15; }
  .crop-btn__label { font-size: 0.58rem; font-weight: 600; color: var(--muted); max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .crop-btn.is-active { border-color: var(--green); background: var(--green-100); }
  .crop-btn.is-active .crop-btn__label { color: var(--green-700); }
  .crop-btn--new { border-style: dashed; }

  .recon { position: absolute; left: 0.6rem; right: 0.6rem; bottom: 5rem; z-index: 6; font-size: 0.74rem; line-height: 1.35; background: color-mix(in srgb, #fff7e6 92%, transparent); border: 1px solid #ecd9a8; color: #6b5310; border-radius: 10px; padding: 0.35rem 0.6rem; backdrop-filter: blur(4px); }

  #plot-svg.zoomed-in image { clip-path: none; }

  .offplot { margin-top: 0.6rem; display: flex; align-items: center; gap: 0.7rem; }
  .offplot__label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); }
  .offplot__card { flex: 1; max-width: 26rem; display: flex; align-items: center; gap: 0.7rem; font: inherit; text-align: left; cursor: pointer; background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius); padding: 0.6rem 0.8rem; box-shadow: var(--shadow-sm); }
  .offplot__card:hover { border-color: var(--green); }
  .offplot__icon { font-size: 1.6rem; }
  .offplot__body { flex: 1; display: flex; flex-direction: column; gap: 0.05rem; }
  .offplot__meta { font-size: 0.78rem; color: var(--muted); }
  .offplot__thumb { width: 3rem; height: 3rem; object-fit: cover; border-radius: 8px; border: 1px solid var(--line); }
  .map-stage:has(.plant-bar:not([hidden])) .map-controls { bottom: 4.6rem; }
  :global(body.plot-fs) .marker-pop { bottom: 4.9rem; }

  .save-state { display: flex; align-items: center; gap: 0.45rem; margin-left: auto; flex-wrap: wrap; font-size: 0.82rem; color: var(--accent); }
  .save-state__label { font-weight: 700; }
  .web-status { color: var(--green-700); }

  .plot__grid { display: flex; justify-content: center; }

  .map-card { background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius); padding: 0.5rem; box-shadow: var(--shadow); }
  /* The plot is a tall 3:1 portrait — shape the stage to it so the overview fills nicely. */
  .map-stage { position: relative; aspect-ratio: 54.955101 / 153.95511; height: min(82vh, 900px); width: auto; margin-inline: auto; border-radius: var(--radius-sm); overflow: hidden; background: #eef0ea; }
  #plot-svg { width: 100%; height: 100%; display: block; touch-action: none; cursor: grab; }
  #plot-svg.is-editing { cursor: default; }
  #plot-svg.is-placing { cursor: crosshair; }

  .map-card--full { position: fixed; inset: 0; z-index: 60; border-radius: 0; padding: 0; }
  .map-card--full .map-stage { aspect-ratio: auto; width: 100%; height: 100dvh; border-radius: 0; }
  :global(body.plot-fs) { overflow: hidden; }

