---
import plotData from '../data/areas.json';
import seedsData from '../data/seeds.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const mapSrc = `${base}/map/plot-base.png`;
const repo = { owner: 'geojenks', name: 'allotment', branch: 'main', path: 'src/data/areas.json' };
---

<section class="plot" id="plot-root">
  <div class="plot__bar">
    <div class="modes" role="group" aria-label="Map mode">
      <button id="mode-view" class="mode is-active" type="button">View</button>
      <button id="mode-edit" class="mode" type="button">Edit</button>
    </div>

    <button id="zoom-btn" type="button" class="ctl" hidden></button>

    <div id="edit-tools" class="edit-tools" hidden>
      <button id="add-area" type="button" class="ctl">+ Area</button>
    </div>

    <div id="save-state" class="save-state" hidden>
      <span class="save-state__label">Unsaved</span>
      <button id="save-web" type="button" class="ctl ctl--primary">Save to website</button>
      <button id="download-json" type="button" class="ctl">Download</button>
      <button id="copy-json" type="button" class="ctl">Copy</button>
      <button id="discard" type="button" class="ctl ctl--ghost">Discard</button>
      <span id="web-status" class="web-status"></span>
    </div>
  </div>

  <div class="plot__grid">
    <div class="map-card" id="map-card">
      <div class="map-stage">
        <svg
          id="plot-svg"
          viewBox="0 0 54.955101 153.95511"
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-label="Interactive map of the allotment plot"
        >
          <defs>
            <clipPath id="mapclip" clipPathUnits="userSpaceOnUse">
              <rect width="54.955101" height="153.95511" x="98.595917" y="49.702042" transform="rotate(135.6319)"></rect>
            </clipPath>
          </defs>
          <g transform="translate(-98.595917,-49.702042)">
            <image href={mapSrc} width="152.39999" height="136.78958" preserveAspectRatio="none"
              x="-259.4986" y="-73.784225" transform="rotate(-135.6319)" clip-path="url(#mapclip)"></image>
            <g id="area-layer"></g>
            <g id="marker-layer"></g>
          </g>
        </svg>

        <div class="map-controls">
          <button id="zin" type="button" title="Zoom in" aria-label="Zoom in">+</button>
          <button id="zout" type="button" title="Zoom out" aria-label="Zoom out">−</button>
          <button id="zreset" type="button" title="Whole plot" aria-label="Whole plot">⤢</button>
          <button id="fs" type="button" title="Fullscreen" aria-label="Fullscreen">⤡</button>
        </div>

        <p id="place-hint" class="place-hint" hidden>Tap inside to place the plant</p>

        <div id="recon" class="recon" hidden></div>

        <div id="plant-bar" class="plant-bar" hidden>
          <div id="palette" class="palette" aria-label="Plant icons"></div>
          <button id="pb-done" type="button" class="ctl ctl--primary">✓ Done</button>
        </div>
      </div>
    </div>

  </div>

  <div id="offplot" class="offplot" hidden>
    <span class="offplot__label">Off the plot</span>
    <button id="gh-card" class="offplot__card" type="button">
      <span class="offplot__icon">🏡</span>
      <span class="offplot__body">
        <strong>Home greenhouse</strong>
        <span id="gh-meta" class="offplot__meta"></span>
      </span>
      <img id="gh-thumb" class="offplot__thumb" alt="" hidden />
    </button>
  </div>

  <div id="area-view" class="area-view" role="dialog" aria-modal="true" hidden>
    <header class="av-bar">
      <button id="av-back" class="ctl ctl--ghost" type="button">← Overview</button>
      <h2 id="av-title" class="av-title"></h2>
      <div class="av-right">
        <button id="av-save" class="ctl ctl--primary" type="button" hidden>Save to website</button>
        <button id="av-edit" class="ctl" type="button">✎ Edit</button>
        <button id="av-prev" class="navbtn" type="button" aria-label="Previous bed">‹</button>
        <button id="av-next" class="navbtn" type="button" aria-label="Next bed">›</button>
      </div>
    </header>
    <div id="info" class="info av-body"></div>
  </div>

  <div id="marker-pop" class="marker-pop" hidden></div>

  <details class="legend">
    <summary>Legend &amp; key</summary>
    <ul id="legend-list"></ul>
  </details>

  <dialog id="export-dialog">
    <form method="dialog">
      <h3>Plot JSON</h3>
      <p>Copied to your clipboard. Paste into <code>src/data/areas.json</code> and push — or just use <strong>Save to website</strong>.</p>
      <textarea id="export-text" rows="12" readonly></textarea>
      <menu><button value="close">Close</button></menu>
    </form>
  </dialog>
</section>

<script define:vars={{ plotData, seedsData, repo, base }}>
  const TYPE_META = {
    bed: { color: '#c98a3b', label: 'Bed' }, tree: { color: '#5f8a36', label: 'Tree' },
    bushes: { color: '#86a948', label: 'Bushes' }, structure: { color: '#7c8aa0', label: 'Structure' },
    water: { color: '#3f86ad', label: 'Water' }, wild: { color: '#9a7b4f', label: 'Wild / rough' },
    unused: { color: '#a9a496', label: 'Unused / open' }, boundary: { color: '#8a8577', label: 'Boundary' },
  };
  const STATUS_LABEL = { planned: 'Planned', sown: 'Sown', growing: 'Growing', harvesting: 'Harvesting', done: 'Done', volunteer: 'Self-seeded' };
  // Generic emoji pool for (re)assigning an icon to a plant.
  const ICONS = ['🥔','🥦','🧅','🧄','🥕','🥬','🍅','🫛','🎃','🥒','🌽','🍓','🫐','🍎','🍐','🍒','🌶️','🍆','🌿','🌷','🌻','🌾','🍇','🍋','🌱'];
  // Best-guess icon from the plant's name.
  const ICON_GUESS = [
    [/potato/i, '🥔'], [/broccoli|psb|cabbage|kale|sprout|cauli|brassica|swede|turnip/i, '🥦'],
    [/onion|shallot|leek/i, '🧅'], [/garlic/i, '🧄'], [/carrot|parsnip|radish|beet/i, '🥕'],
    [/lettuce|salad|chard|spinach|rocket|leaf/i, '🥬'], [/tomato/i, '🍅'], [/pea|bean/i, '🫛'],
    [/squash|pumpkin|courgette|marrow/i, '🎃'], [/cucumber|gherkin/i, '🥒'], [/corn/i, '🌽'],
    [/strawberr/i, '🍓'], [/raspberr|blackberr|currant|gooseberr|berry/i, '🫐'],
    [/apple/i, '🍎'], [/pear/i, '🍐'], [/cherry|plum/i, '🍒'], [/pepper|chilli/i, '🌶️'], [/aubergine/i, '🍆'],
    [/basil|herb|mint|parsley|coriander|thyme|rosemary|sage|dill|chive/i, '🌿'],
    [/asparagus|rhubarb/i, '🌾'], [/flower|dahlia|sunflower|marigold|cosmos/i, '🌻'], [/grape/i, '🍇'],
  ];
  const guessIcon = (name) => { for (const [re, ic] of ICON_GUESS) if (re.test(name || '')) return ic; return '🌱'; };
  // Marker condition → colour; slug collar ("fortified") darkens the ring.
  const COND = { growing: '#3f7d2f', struggling: '#d99a2b', eaten: '#b3402f', dead: '#6b6b6b' };
  const COND_LABEL = { growing: 'Growing well', struggling: 'Partly eaten but alive', eaten: 'Decimated by slugs', dead: 'Dead / gone' };
  const fillOf = (m) => COND[m.condition] || COND.growing;
  const strokeOf = (m) => (m.fortified ? '#33322e' : fillOf(m));

  const SVGNS = 'http://www.w3.org/2000/svg';
  const STORE_KEY = 'allotment:plot:v1';
  const TOKEN_KEY = 'allotment:gh-token';
  const PLOT = { x: 0, y: 0, w: 54.955101, h: 153.95511 };
  const TX = -98.595917, TY = -49.702042;

  // ---- state + persistence ----------------------------------------------
  const baseline = { areas: plotData.areas, markers: plotData.markers || [], cropIcons: plotData.cropIcons || {} };
  let baselineJSON = JSON.stringify(baseline);
  const djb2 = (s) => { let h = 5381; for (let i = 0; i < s.length; i++) h = ((h * 33) ^ s.charCodeAt(i)) >>> 0; return h.toString(36); };
  function loadState() {
    try {
      const raw = localStorage.getItem(STORE_KEY);
      if (raw) {
        const p = JSON.parse(raw);
        // If the site has moved on (published from elsewhere) and this device had
        // nothing unsaved when it last wrote, drop the stale local snapshot.
        const stale = p.base && p.base !== djb2(baselineJSON) && !p.dirty;
        if (!stale && p && Array.isArray(p.areas)) return { areas: p.areas, markers: p.markers || [], cropIcons: p.cropIcons || {} };
      }
    } catch {}
    return JSON.parse(baselineJSON);
  }
  const st = loadState();
  let areas = st.areas, markers = st.markers, cropIcons = st.cropIcons;
  let saveTimer = null;
  function save() {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(() => {
      try { localStorage.setItem(STORE_KEY, JSON.stringify({ areas, markers, cropIcons, base: djb2(baselineJSON), dirty: isDirty() })); } catch {}
      updateSaveState();
    }, 150);
  }
  const isDirty = () => JSON.stringify({ areas, markers, cropIcons }) !== baselineJSON;

  // Live sowings (for the crop palette + planner reconciliation): prefer the
  // seeds page's unsaved localStorage overlay over the build-time file.
  let sowings = seedsData.sowings || [];
  try { const raw = localStorage.getItem('allotment:seeds:v1'); if (raw) sowings = JSON.parse(raw).sowings || sowings; } catch {}
  const iconFor = (crop) => cropIcons[crop] || guessIcon(crop);

  // ---- refs --------------------------------------------------------------
  const root = document.getElementById('plot-root');
  // Stamp Astro's scope attribute onto JS-created nodes so scoped <style> applies.
  const SCOPE = (() => {
    const cid = root ? Array.from(root.attributes).map((a) => a.name).find((n) => n.startsWith('data-astro-cid-')) : null;
    return (el) => { if (cid && el) { el.setAttribute(cid, ''); el.querySelectorAll('*').forEach((n) => n.setAttribute(cid, '')); } return el; };
  })();
  const mapCard = document.getElementById('map-card');
  const svg = document.getElementById('plot-svg');
  const areaLayer = document.getElementById('area-layer');
  const markerLayer = document.getElementById('marker-layer');
  const info = document.getElementById('info');
  const editTools = document.getElementById('edit-tools');
  const plantBar = document.getElementById('plant-bar');
  const palette = document.getElementById('palette');
  const addAreaBtn = document.getElementById('add-area');
  const placeHint = document.getElementById('place-hint');
  const exportDialog = document.getElementById('export-dialog');
  const zoomBtn = document.getElementById('zoom-btn');
  const saveStateEl = document.getElementById('save-state');
  const saveLabel = saveStateEl.querySelector('.save-state__label');
  const webStatus = document.getElementById('web-status');
  const areaView = document.getElementById('area-view');
  const avTitle = document.getElementById('av-title');
  const avBack = document.getElementById('av-back');
  const avEdit = document.getElementById('av-edit');
  const avPrev = document.getElementById('av-prev');
  const avNext = document.getElementById('av-next');
  const avSave = document.getElementById('av-save');
  const markerPop = document.getElementById('marker-pop');
  let overlayId = null;
  // Lift the overlay + popover out to <body> so they sit above the sticky header
  // regardless of any stacking context the page layout introduces.
  document.body.append(areaView, markerPop);

  let mode = 'view', tool = 'select', placeCrop = null;
  let selected = null, focusedAreaId = null;
  const areaNodes = new Map(), markerNodes = new Map();

  // ---- geometry / pan-zoom ----------------------------------------------
  let vb = { ...PLOT };
  let overviewVB = { ...PLOT };
  let minW = 4, maxW = PLOT.w;

  const elAspect = () => {
    const r = svg.getBoundingClientRect();
    return r.height > 0 ? r.width / r.height : PLOT.w / PLOT.h;
  };
  function fitBounds(b, pad = 0) {
    const EA = elAspect();
    let w = b.w + pad * 2, h = b.h + pad * 2;
    if (w / h < EA) w = h * EA; else h = w / EA;
    return { x: b.x + b.w / 2 - w / 2, y: b.y + b.h / 2 - h / 2, w, h };
  }
  // "Home" view: on wide-relative stages (phone full-width) fill the width and
  // pan up/down the plot; on tall stages (desktop strip) fit the whole plot.
  function homeView(cy) {
    const EA = elAspect();
    if (EA <= (PLOT.w / PLOT.h) * 1.45) return fitBounds(PLOT, 1);
    const w = PLOT.w + 2, h = w / EA;
    let y = (cy ?? PLOT.y + h / 2) - h / 2;
    y = Math.min(Math.max(y, PLOT.y - 1), PLOT.y + PLOT.h + 1 - h);
    return { x: PLOT.x + PLOT.w / 2 - w / 2, y, w, h };
  }
  let didLayout = false;
  function relayout() {
    overviewVB = fitBounds(PLOT, 1);
    maxW = overviewVB.w; minW = PLOT.w / 12;
    if (focusedAreaId) { const a = areas.find((x) => x.id === focusedAreaId); if (a) setVB(focusVB(a)); }
    else if (didLayout && vb.w < overviewVB.w * 0.9) { /* user has zoomed in — keep it */ clampPan(); writeVB(); }
    else setVB(homeView());
    didLayout = true;
  }
  function focusVB(a) {
    return fitBounds({ x: a.shape.x + TX, y: a.shape.y + TY, w: a.shape.w, h: a.shape.h }, 0.8);
  }
  let raf = null;
  function readVB() { const c = svg.viewBox.baseVal; vb = { x: c.x, y: c.y, w: c.width, h: c.height }; }
  function writeVB() {
    svg.setAttribute('viewBox', `${vb.x} ${vb.y} ${vb.w} ${vb.h}`);
    // Zoomed in: lift the aerial photo's plot-outline crop so edges fill in.
    svg.classList.toggle('zoomed-in', vb.w < overviewVB.w * 0.92);
  }
  function setVB(target, animate) {
    cancelAnimationFrame(raf);
    if (!animate) { vb = { ...target }; clampPan(); writeVB(); return; }
    const from = { ...vb }, t0 = performance.now(), dur = 280;
    const tick = (now) => {
      const k = Math.min(1, (now - t0) / dur), e = k < 0.5 ? 2 * k * k : 1 - Math.pow(-2 * k + 2, 2) / 2;
      vb = { x: from.x + (target.x - from.x) * e, y: from.y + (target.y - from.y) * e,
        w: from.w + (target.w - from.w) * e, h: from.h + (target.h - from.h) * e };
      writeVB();
      if (k < 1) raf = requestAnimationFrame(tick); else { vb = { ...target }; clampPan(); writeVB(); }
    };
    raf = requestAnimationFrame(tick);
  }
  function clampPan() {
    const mx = vb.w * 0.3, my = vb.h * 0.3;
    const minX = overviewVB.x - mx, maxX = overviewVB.x + overviewVB.w - vb.w + mx;
    const minY = overviewVB.y - my, maxY = overviewVB.y + overviewVB.h - vb.h + my;
    vb.x = maxX < minX ? (minX + maxX) / 2 : Math.min(Math.max(vb.x, minX), maxX);
    vb.y = maxY < minY ? (minY + maxY) / 2 : Math.min(Math.max(vb.y, minY), maxY);
  }
  function applyZoom(baseVB, newW, fx, fy) {
    newW = Math.min(Math.max(newW, minW), maxW);
    const ratio = newW / baseVB.w;
    vb = { w: newW, h: baseVB.h * ratio, x: fx - (fx - baseVB.x) * ratio, y: fy - (fy - baseVB.y) * ratio };
    clampPan(); writeVB();
  }
  function screenToRoot(cx, cy) {
    const pt = svg.createSVGPoint(); pt.x = cx; pt.y = cy;
    return pt.matrixTransform(svg.getScreenCTM().inverse());
  }
  function toLocal(cx, cy) {
    const pt = svg.createSVGPoint(); pt.x = cx; pt.y = cy;
    return pt.matrixTransform(areaLayer.getScreenCTM().inverse());
  }

  function zoomToArea(id) {
    const a = areas.find((x) => x.id === id); if (!a) return;
    focusedAreaId = id; setVB(focusVB(a), true); refreshChrome();
  }
  function zoomOut() {
    const a = areas.find((x) => x.id === focusedAreaId);
    const cy = a ? a.shape.y + TY + a.shape.h / 2 : undefined; // keep the bed in view
    focusedAreaId = null; setTool('select'); setVB(homeView(cy), true); refreshChrome();
  }

  // ---- helpers -----------------------------------------------------------
  function el(name, attrs) { const n = document.createElementNS(SVGNS, name); for (const [k, v] of Object.entries(attrs || {})) n.setAttribute(k, v); return n; }
  const colorFor = (a) => (TYPE_META[a.type] || TYPE_META.unused).color;
  const uid = (p) => p + Math.random().toString(36).slice(2, 8);
  const round = (n) => Math.round(n * 1000) / 1000;
  const markersInArea = (a) => markers.filter((m) => m.x >= a.shape.x && m.x <= a.shape.x + a.shape.w && m.y >= a.shape.y && m.y <= a.shape.y + a.shape.h);

  // ---- render areas ------------------------------------------------------
  // Off-plot places (the home greenhouse) get their own framed card below the
  // map instead of a rectangle on the aerial photo.
  const OFF_PLOT = new Set(['home-greenhouse']);
  function renderAreas() { areaLayer.replaceChildren(); areaNodes.clear(); areas.filter((a) => !OFF_PLOT.has(a.id)).forEach((a, i) => renderArea(a, i + 1)); updatePlantCounts(); }
  function renderArea(area, number) {
    const c = colorFor(area), s = area.shape;
    const g = el('g', { class: 'area', 'data-id': area.id });
    const rect = el('rect', { x: s.x, y: s.y, width: s.w, height: s.h, rx: 0.8, fill: c, 'fill-opacity': 0.26, stroke: c, 'stroke-width': 0.5 });
    const badge = el('circle', { cx: s.x + 2.4, cy: s.y + 2.4, r: 1.8, fill: c, stroke: '#fff', 'stroke-width': 0.32 });
    const badgeText = el('text', { x: s.x + 2.4, y: s.y + 2.4, 'text-anchor': 'middle', 'dominant-baseline': 'central', 'font-size': 2.1, fill: '#fff', 'font-family': 'system-ui, sans-serif' });
    badgeText.textContent = String(number);
    const count = el('text', { x: s.x + s.w - 1, y: s.y + s.h - 1, 'text-anchor': 'end', 'font-size': 2.6, fill: '#1f3a17', stroke: '#fff', 'stroke-width': 0.5, 'paint-order': 'stroke', 'font-family': 'system-ui, sans-serif', class: 'plant-count' });
    const handle = el('rect', { x: s.x + s.w - 1.6, y: s.y + s.h - 1.6, width: 1.6, height: 1.6, fill: '#fff', stroke: c, 'stroke-width': 0.4, class: 'handle' });
    handle.style.display = 'none';
    g.append(rect, badge, badgeText, count, handle);
    areaLayer.append(g);
    areaNodes.set(area.id, { group: g, rect, badge, badgeText, count, handle, number });
    g.addEventListener('mouseenter', () => g.classList.add('is-hover'));
    g.addEventListener('mouseleave', () => g.classList.remove('is-hover'));
    SCOPE(g);
  }
  function syncArea(area) {
    const n = areaNodes.get(area.id); if (!n) return; const s = area.shape;
    n.rect.setAttribute('x', s.x); n.rect.setAttribute('y', s.y); n.rect.setAttribute('width', s.w); n.rect.setAttribute('height', s.h);
    n.badge.setAttribute('cx', s.x + 2.4); n.badge.setAttribute('cy', s.y + 2.4);
    n.badgeText.setAttribute('x', s.x + 2.4); n.badgeText.setAttribute('y', s.y + 2.4);
    n.count.setAttribute('x', s.x + s.w - 1); n.count.setAttribute('y', s.y + s.h - 1);
    n.handle.setAttribute('x', s.x + s.w - 1.6); n.handle.setAttribute('y', s.y + s.h - 1.6);
    const c = colorFor(area); for (const nd of [n.rect, n.badge, n.handle]) nd.setAttribute('stroke', c);
    n.rect.setAttribute('fill', c); n.badge.setAttribute('fill', c);
  }
  function updatePlantCounts() {
    for (const [id, n] of areaNodes) { const a = areas.find((x) => x.id === id); const c = a ? markersInArea(a).length : 0; n.count.textContent = c ? `🌱${c}` : ''; }
    updateRecon();
  }

  // ---- map ↔ planner reconciliation (soft — informs, never blocks) --------
  const cap = (s) => s.charAt(0).toUpperCase() + s.slice(1);
  function reconLines(areaId) {
    const a = areas.find((x) => x.id === areaId); if (!a) return [];
    const iconCounts = new Map();
    for (const m of markersInArea(a)) { const k = (m.crop || m.label || 'plant').toLowerCase(); iconCounts.set(k, (iconCounts.get(k) || 0) + 1); }
    const planCounts = new Map();
    for (const s of sowings) {
      if (s.stage === 'planted-out' && s.destinationAreaId === areaId) { const k = s.crop.toLowerCase(); planCounts.set(k, (planCounts.get(k) || 0) + (s.qty || 1)); }
    }
    const lines = [];
    for (const n of [...new Set([...iconCounts.keys(), ...planCounts.keys()])].sort()) {
      const i = iconCounts.get(n) || 0, p = planCounts.get(n) || 0;
      if (i === p || p === 0) continue; // only flag when the planner and map disagree
      if (i === 0) lines.push(`${cap(n)}: ${p} planted out in the planner, no icons dropped yet`);
      else lines.push(`${cap(n)}: ${p} in the planner vs ${i} icon${i === 1 ? '' : 's'} here`);
    }
    // icons with no planner entry at all (only mention crops that exist in sowings, to avoid nagging about trees etc.)
    for (const [n, i] of iconCounts) {
      if (planCounts.has(n)) continue;
      if (sowings.some((s) => s.crop.toLowerCase() === n && s.stage !== 'failed')) lines.push(`${cap(n)}: ${i} icon${i === 1 ? '' : 's'} here, none planted out here in the planner`);
    }
    return lines;
  }
  function updateRecon() {
    const el = document.getElementById('recon');
    if (!el) return;
    if (!(mode === 'edit' && focusedAreaId)) { el.hidden = true; return; }
    const lines = reconLines(focusedAreaId);
    el.hidden = !lines.length;
    if (lines.length) el.textContent = '📋 ' + lines.join('  ·  ');
  }

  // ---- render markers ----------------------------------------------------
  function renderMarkers() { markerLayer.replaceChildren(); markerNodes.clear(); markers.forEach((m) => renderMarker(m)); }
  const glyphSize = (m) => Math.max(1.3, Math.min(m.r * 1.7, 7));
  function renderMarker(m) {
    const g = el('g', { class: 'marker', 'data-id': m.id });
    const circle = el('circle', { cx: m.x, cy: m.y, r: m.r, fill: fillOf(m), 'fill-opacity': 0.16, stroke: strokeOf(m), 'stroke-width': m.fortified ? 0.55 : 0.4 });
    const glyph = el('text', { x: m.x, y: m.y, 'text-anchor': 'middle', 'dominant-baseline': 'central', 'font-size': glyphSize(m) });
    glyph.textContent = m.icon;
    const handle = el('circle', { cx: m.x + m.r, cy: m.y, r: 0.7, fill: '#fff', stroke: '#3f7d2f', 'stroke-width': 0.35, class: 'handle' });
    handle.style.display = 'none';
    g.append(circle, glyph, handle); markerLayer.append(g);
    markerNodes.set(m.id, { group: g, circle, glyph, handle });
    SCOPE(g);
  }
  function syncMarker(m) {
    const n = markerNodes.get(m.id); if (!n) return;
