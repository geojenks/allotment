---
import plotData from '../data/areas.json';

// BASE_URL may be "/allotment" (no trailing slash) or "/", so join safely.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const mapSrc = `${base}/map/plot-base.png`;
---

<section class="plot">
  <div class="plot__bar">
    <div class="modes" role="group" aria-label="Map mode">
      <button id="mode-view" class="mode is-active" type="button">View</button>
      <button id="mode-edit" class="mode" type="button">Edit</button>
    </div>

    <div id="edit-tools" class="edit-tools" hidden>
      <button id="add-area" type="button">+ Area</button>
      <div id="palette" class="palette" aria-label="Plant icons"></div>
    </div>

    <div id="save-state" class="save-state" hidden>
      <span class="dot"></span>
      <span class="save-state__label">Saved on this device</span>
      <button id="download-json" type="button">Download</button>
      <button id="copy-json" type="button">Copy</button>
      <button id="discard" type="button" class="ghost">Discard</button>
    </div>
  </div>

  <div class="plot__grid">
    <div class="map-wrap">
      <svg
        id="plot-svg"
        viewBox="0 0 54.955101 153.95511"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="Interactive map of the allotment plot"
      >
        <defs>
          <clipPath id="mapclip" clipPathUnits="userSpaceOnUse">
            <rect
              width="54.955101"
              height="153.95511"
              x="98.595917"
              y="49.702042"
              transform="rotate(135.6319)"></rect>
          </clipPath>
        </defs>
        <!-- Same coordinate system as figures/plot_overlay.svg so areas line up. -->
        <g transform="translate(-98.595917,-49.702042)">
          <image
            href={mapSrc}
            width="152.39999"
            height="136.78958"
            preserveAspectRatio="none"
            x="-259.4986"
            y="-73.784225"
            transform="rotate(-135.6319)"
            clip-path="url(#mapclip)"></image>
          <g id="area-layer"></g>
          <g id="marker-layer"></g>
        </g>
      </svg>
      <p id="place-hint" class="place-hint" hidden>Tap the plot to place the plant.</p>
    </div>

    <aside id="info" class="info">
      <p class="info__empty">Tap an area on the plan to see what's there.</p>
    </aside>
  </div>

  <details class="legend">
    <summary>Legend &amp; key</summary>
    <ul id="legend-list"></ul>
  </details>

  <dialog id="export-dialog">
    <form method="dialog">
      <h3>Plot JSON</h3>
      <p>
        Copied to your clipboard. To make these changes permanent (and visible on
        other devices / the live site), paste this into
        <code>src/data/areas.json</code> and push — or use the Download button.
      </p>
      <textarea id="export-text" rows="12" readonly></textarea>
      <menu><button value="close">Close</button></menu>
    </form>
  </dialog>
</section>

<script define:vars={{ plotData, base }}>
  const TYPE_META = {
    bed: { color: '#c98a3b', label: 'Bed' },
    tree: { color: '#5f8a36', label: 'Tree' },
    bushes: { color: '#86a948', label: 'Bushes' },
    structure: { color: '#7c8aa0', label: 'Structure' },
    water: { color: '#3f86ad', label: 'Water' },
    wild: { color: '#9a7b4f', label: 'Wild / rough' },
    unused: { color: '#a9a496', label: 'Unused / open' },
    boundary: { color: '#8a8577', label: 'Boundary' },
  };

  const STATUS_LABEL = {
    planned: 'Planned',
    sown: 'Sown',
    growing: 'Growing',
    harvesting: 'Harvesting',
    done: 'Done',
    volunteer: 'Self-seeded',
  };

  // Plant icon palette. value is the emoji glyph drawn on the map.
  const ICONS = [
    { icon: '🥔', label: 'Potato' },
    { icon: '🥦', label: 'Brassica' },
    { icon: '🧅', label: 'Onion' },
    { icon: '🧄', label: 'Garlic' },
    { icon: '🥕', label: 'Carrot / root' },
    { icon: '🥬', label: 'Leafy / salad' },
    { icon: '🍅', label: 'Tomato' },
    { icon: '🫛', label: 'Peas / beans' },
    { icon: '🎃', label: 'Squash' },
    { icon: '🌽', label: 'Sweetcorn' },
    { icon: '🍓', label: 'Strawberry' },
    { icon: '🫐', label: 'Berry' },
    { icon: '🌿', label: 'Herb' },
    { icon: '🌷', label: 'Flower' },
    { icon: '🌱', label: 'Seedling' },
  ];

  const SVGNS = 'http://www.w3.org/2000/svg';
  const STORE_KEY = 'allotment:plot:v1';

  // ---- state + persistence ----------------------------------------------

  const baseline = {
    areas: plotData.areas,
    markers: plotData.markers || [],
  };
  const baselineJSON = JSON.stringify(baseline);

  function loadState() {
    try {
      const raw = localStorage.getItem(STORE_KEY);
      if (raw) {
        const parsed = JSON.parse(raw);
        if (parsed && Array.isArray(parsed.areas)) {
          return { areas: parsed.areas, markers: parsed.markers || [] };
        }
      }
    } catch {}
    return JSON.parse(baselineJSON); // fresh clone of the committed data
  }

  const state = loadState();
  let areas = state.areas;
  let markers = state.markers;

  let saveTimer = null;
  function save() {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(() => {
      try {
        localStorage.setItem(STORE_KEY, JSON.stringify({ areas, markers }));
      } catch {}
      updateSaveState();
    }, 150);
  }

  function isDirty() {
    return JSON.stringify({ areas, markers }) !== baselineJSON;
  }

  const saveState = document.getElementById('save-state');
  const saveLabel = saveState.querySelector('.save-state__label');
  function updateSaveState() {
    const dirty = isDirty();
    saveState.hidden = !dirty;
    if (dirty) saveLabel.textContent = 'Unsaved to repo — saved on this device';
  }

  // ---- helpers -----------------------------------------------------------

  const svg = document.getElementById('plot-svg');
  const areaLayer = document.getElementById('area-layer');
  const markerLayer = document.getElementById('marker-layer');
  const info = document.getElementById('info');
  const editTools = document.getElementById('edit-tools');
  const placeHint = document.getElementById('place-hint');
  const exportDialog = document.getElementById('export-dialog');

  let mode = 'view'; // 'view' | 'edit'
  let tool = 'select'; // 'select' | 'place'
  let placeIcon = null; // chosen palette entry while placing
  let selected = null; // { kind: 'area'|'marker', id }
  const areaNodes = new Map();
  const markerNodes = new Map();

  function el(name, attrs) {
    const node = document.createElementNS(SVGNS, name);
    for (const [k, v] of Object.entries(attrs || {})) node.setAttribute(k, v);
    return node;
  }
  function colorFor(area) {
    return (TYPE_META[area.type] || TYPE_META.unused).color;
  }
  function uid(prefix) {
    return prefix + Math.random().toString(36).slice(2, 8);
  }
  function toLocal(evt) {
    const pt = svg.createSVGPoint();
    pt.x = evt.clientX;
    pt.y = evt.clientY;
    return pt.matrixTransform(areaLayer.getScreenCTM().inverse());
  }
  function round(n) {
    return Math.round(n * 1000) / 1000;
  }
  function markersInArea(area) {
    return markers.filter(
      (m) =>
        m.x >= area.shape.x &&
        m.x <= area.shape.x + area.shape.w &&
        m.y >= area.shape.y &&
        m.y <= area.shape.y + area.shape.h
    );
  }

  // ---- rendering: areas --------------------------------------------------

  function renderAreas() {
    areaLayer.replaceChildren();
    areaNodes.clear();
    areas.forEach((area, i) => renderArea(area, i + 1));
  }

  function renderArea(area, number) {
    const c = colorFor(area);
    const g = el('g', { class: 'area', 'data-id': area.id });
    const rect = el('rect', {
      x: area.shape.x,
      y: area.shape.y,
      width: area.shape.w,
      height: area.shape.h,
      rx: 0.8,
      fill: c,
      'fill-opacity': 0.28,
      stroke: c,
      'stroke-width': 0.55,
    });
    const badge = el('circle', {
      cx: area.shape.x + 2.4,
      cy: area.shape.y + 2.4,
      r: 1.8,
      fill: c,
      stroke: '#fff',
      'stroke-width': 0.32,
    });
    const badgeText = el('text', {
      x: area.shape.x + 2.4,
      y: area.shape.y + 2.4,
      'text-anchor': 'middle',
      'dominant-baseline': 'central',
      'font-size': 2.1,
      fill: '#fff',
      'font-family': 'system-ui, sans-serif',
    });
    badgeText.textContent = String(number);
    const handle = el('rect', {
      x: area.shape.x + area.shape.w - 1.6,
      y: area.shape.y + area.shape.h - 1.6,
      width: 1.6,
      height: 1.6,
      fill: '#fff',
      stroke: c,
      'stroke-width': 0.4,
      class: 'handle',
    });
    handle.style.display = 'none';

    g.append(rect, badge, badgeText, handle);
    areaLayer.append(g);
    areaNodes.set(area.id, { group: g, rect, badge, badgeText, handle, number });

    g.addEventListener('mouseenter', () => g.classList.add('is-hover'));
    g.addEventListener('mouseleave', () => g.classList.remove('is-hover'));
    g.addEventListener('pointerdown', (e) => onAreaDown(e, area));
  }

  function syncArea(area) {
    const n = areaNodes.get(area.id);
    if (!n) return;
    const s = area.shape;
    n.rect.setAttribute('x', s.x);
    n.rect.setAttribute('y', s.y);
    n.rect.setAttribute('width', s.w);
    n.rect.setAttribute('height', s.h);
    n.badge.setAttribute('cx', s.x + 2.4);
    n.badge.setAttribute('cy', s.y + 2.4);
    n.badgeText.setAttribute('x', s.x + 2.4);
    n.badgeText.setAttribute('y', s.y + 2.4);
    n.handle.setAttribute('x', s.x + s.w - 1.6);
    n.handle.setAttribute('y', s.y + s.h - 1.6);
    const c = colorFor(area);
    for (const node of [n.rect, n.badge, n.handle]) node.setAttribute('stroke', c);
    n.rect.setAttribute('fill', c);
    n.badge.setAttribute('fill', c);
  }

  // ---- rendering: markers ------------------------------------------------

  function renderMarkers() {
    markerLayer.replaceChildren();
    markerNodes.clear();
    markers.forEach((m) => renderMarker(m));
  }

  function renderMarker(m) {
    const g = el('g', { class: 'marker', 'data-id': m.id });
    const circle = el('circle', {
      cx: m.x,
      cy: m.y,
      r: m.r,
      fill: '#3f7d2f',
      'fill-opacity': 0.16,
      stroke: '#3f7d2f',
      'stroke-width': 0.4,
    });
    const glyph = el('text', {
      x: m.x,
      y: m.y,
      'text-anchor': 'middle',
      'dominant-baseline': 'central',
      'font-size': Math.max(2.4, Math.min(m.r * 1.4, 6)),
    });
    glyph.textContent = m.icon;
    const handle = el('circle', {
      cx: m.x + m.r,
      cy: m.y,
      r: 1.1,
      fill: '#fff',
      stroke: '#3f7d2f',
      'stroke-width': 0.45,
      class: 'handle',
    });
    handle.style.display = 'none';
    g.append(circle, glyph, handle);
    markerLayer.append(g);
    markerNodes.set(m.id, { group: g, circle, glyph, handle });
    g.addEventListener('pointerdown', (e) => onMarkerDown(e, m));
  }

  function syncMarker(m) {
    const n = markerNodes.get(m.id);
    if (!n) return;
    n.circle.setAttribute('cx', m.x);
    n.circle.setAttribute('cy', m.y);
    n.circle.setAttribute('r', m.r);
    n.glyph.setAttribute('x', m.x);
    n.glyph.setAttribute('y', m.y);
    n.glyph.setAttribute('font-size', Math.max(2.4, Math.min(m.r * 1.4, 6)));
    n.glyph.textContent = m.icon;
    n.handle.setAttribute('cx', m.x + m.r);
    n.handle.setAttribute('cy', m.y);
  }

  // ---- selection ---------------------------------------------------------

  function refreshSelection() {
    for (const [id, n] of areaNodes) {
      const sel = selected?.kind === 'area' && selected.id === id;
      n.group.classList.toggle('is-selected', sel);
      n.handle.style.display = mode === 'edit' && tool === 'select' && sel ? '' : 'none';
    }
    for (const [id, n] of markerNodes) {
      const sel = selected?.kind === 'marker' && selected.id === id;
      n.group.classList.toggle('is-selected', sel);
      n.handle.style.display = mode === 'edit' && tool === 'select' && sel ? '' : 'none';
    }
  }

  function selectArea(id) {
    selected = { kind: 'area', id };
    refreshSelection();
    renderInfo();
  }
  function selectMarker(id) {
    selected = { kind: 'marker', id };
    refreshSelection();
    renderInfo();
  }
  function clearSelection() {
    selected = null;
    refreshSelection();
    renderInfo();
  }

  // ---- info panel --------------------------------------------------------

  function tag(text, cls) {
    const s = document.createElement('span');
    s.className = 'tag ' + (cls || '');
    s.textContent = text;
    return s;
  }
  function dateRange(from, to) {
    const fmt = (d) =>
      new Date(d).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
    if (from && to) return `${fmt(from)} – ${fmt(to)}`;
    if (from) return `from ${fmt(from)}`;
    if (to) return `until ${fmt(to)}`;
    return '';
  }
  function emptyInfo(msg) {
    info.replaceChildren();
    const p = document.createElement('p');
    p.className = 'info__empty';
    p.textContent = msg;
    info.append(p);
  }

  function renderInfo() {
    if (!selected) {
      emptyInfo(
        mode === 'edit'
          ? 'Tap an area to edit it, drag to move, or pick a plant icon to drop one in.'
          : "Tap an area on the plan to see what's there."
      );
      return;
    }
    if (selected.kind === 'marker') {
      const m = markers.find((x) => x.id === selected.id);
      if (!m) return emptyInfo('Select something on the plan.');
      return mode === 'edit' ? info.replaceChildren(markerForm(m)) : renderMarkerInfo(m);
    }
    const area = areas.find((a) => a.id === selected.id);
    if (!area) return emptyInfo('Select something on the plan.');
    return mode === 'edit' ? info.replaceChildren(areaForm(area)) : renderAreaInfo(area);
  }

  function renderAreaInfo(area) {
    info.replaceChildren();
    const meta = TYPE_META[area.type] || TYPE_META.unused;
    const h = document.createElement('h2');
    h.textContent = area.name;
    info.append(h);

    const tags = document.createElement('div');
    tags.className = 'tags';
    const t = tag(meta.label);
    t.style.setProperty('--tag', meta.color);
    tags.append(t);
    if (area.provisional) tags.append(tag('name unconfirmed', 'tag--warn'));
    info.append(tags);

    if (area.notes) {
      const p = document.createElement('p');
      p.className = 'notes';
      p.textContent = area.notes;
      info.append(p);
    }

    const inArea = markersInArea(area);
    if (inArea.length) {
      const hh = document.createElement('h3');
      hh.textContent = 'Plants here';
      info.append(hh);
      const row = document.createElement('div');
      row.className = 'plant-chips';
      for (const m of inArea) {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = 'plant-chip';
        chip.textContent = `${m.icon} ${m.label || ''}`.trim();
        chip.addEventListener('click', () => selectMarker(m.id));
        row.append(chip);
      }
      info.append(row);
    }

    if (area.plantings?.length) {
      const hh = document.createElement('h3');
      hh.textContent = 'Planted';
      info.append(hh);
      const ul = document.createElement('ul');
      ul.className = 'plantings';
      for (const p of area.plantings) {
        const li = document.createElement('li');
        const title = document.createElement('strong');
        title.textContent = p.variety ? `${p.crop} — ${p.variety}` : p.crop;
        li.append(title);
        const meta2 = document.createElement('div');
        meta2.className = 'planting-meta';
        meta2.append(tag(STATUS_LABEL[p.status] || p.status, 'tag--soft'));
        const range = dateRange(p.harvestFrom, p.harvestTo);
        if (range) {
          const r = document.createElement('span');
          r.className = 'muted';
          r.textContent = `harvest ${range}`;
          meta2.append(r);
        }
        li.append(meta2);
        if (p.notes) {
          const n = document.createElement('div');
          n.className = 'muted small';
          n.textContent = p.notes;
          li.append(n);
        }
        ul.append(li);
      }
      info.append(ul);
    }

    if (area.tasks?.length) {
      const hh = document.createElement('h3');
      hh.textContent = 'To do';
      info.append(hh);
      const ul = document.createElement('ul');
      ul.className = 'tasks';
      for (const tk of area.tasks) {
        const li = document.createElement('li');
        li.textContent = tk.title + (tk.notes ? ` — ${tk.notes}` : '');
        ul.append(li);
      }
      info.append(ul);
    }

    if (!inArea.length && !area.plantings?.length && !area.tasks?.length && !area.notes) {
      const p = document.createElement('p');
      p.className = 'muted';
      p.textContent = 'Nothing recorded here yet.';
      info.append(p);
    }
  }

  function renderMarkerInfo(m) {
    info.replaceChildren();
    const h = document.createElement('h2');
    h.textContent = `${m.icon} ${m.label || 'Plant'}`;
    info.append(h);
    const host = areas.find(
      (a) =>
        m.x >= a.shape.x &&
        m.x <= a.shape.x + a.shape.w &&
        m.y >= a.shape.y &&
        m.y <= a.shape.y + a.shape.h
    );
    const p = document.createElement('p');
    p.className = 'muted';
    p.textContent = host ? `In: ${host.name}` : 'Not inside a mapped area.';
    info.append(p);
  }

  // ---- edit forms --------------------------------------------------------

  function field(labelText, inputEl) {
    const wrap = document.createElement('label');
    wrap.className = 'field';
    const span = document.createElement('span');
    span.textContent = labelText;
    wrap.append(span, inputEl);
    return wrap;
  }

  function areaForm(area) {
    const frag = document.createDocumentFragment();
    const h = document.createElement('h2');
    h.textContent = 'Edit area';
    frag.append(h);

    const name = document.createElement('input');
    name.type = 'text';
    name.value = area.name;
    name.addEventListener('input', () => {
      area.name = name.value;
      save();
    });
    frag.append(field('Name', name));

    const type = document.createElement('select');
    for (const [val, m] of Object.entries(TYPE_META)) {
      const opt = document.createElement('option');
      opt.value = val;
      opt.textContent = m.label;
      if (val === area.type) opt.selected = true;
      type.append(opt);
    }
    type.addEventListener('change', () => {
      area.type = type.value;
      syncArea(area);
      save();
    });
    frag.append(field('Type', type));

    const notes = document.createElement('textarea');
    notes.rows = 3;
    notes.value = area.notes || '';
    notes.addEventListener('input', () => {
      area.notes = notes.value;
      save();
    });
    frag.append(field('Notes', notes));

    const confirmRow = document.createElement('label');
    confirmRow.className = 'field field--check';
    const cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.checked = !area.provisional;
    cb.addEventListener('change', () => {
      area.provisional = !cb.checked;
      save();
    });
    const cspan = document.createElement('span');
    cspan.textContent = 'Name confirmed';
    confirmRow.append(cb, cspan);
    frag.append(confirmRow);

    const del = document.createElement('button');
    del.type = 'button';
    del.className = 'danger';
    del.textContent = 'Delete area';
    del.addEventListener('click', () => {
      const i = areas.findIndex((a) => a.id === area.id);
      if (i >= 0) areas.splice(i, 1);
      clearSelection();
      renderAreas();
      refreshSelection();
      save();
    });
    frag.append(del);
    return frag;
  }

  function markerForm(m) {
    const frag = document.createDocumentFragment();
    const h = document.createElement('h2');
    h.textContent = 'Edit plant';
    frag.append(h);

    // icon picker
    const iconWrap = document.createElement('div');
    iconWrap.className = 'icon-grid';
    for (const it of ICONS) {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'icon-btn' + (it.icon === m.icon ? ' is-active' : '');
      b.textContent = it.icon;
      b.title = it.label;
      b.addEventListener('click', () => {
        m.icon = it.icon;
        if (!m.label) m.label = it.label;
        syncMarker(m);
        renderInfo();
        save();
      });
      iconWrap.append(b);
    }
    frag.append(field('Icon', iconWrap));

    const label = document.createElement('input');
    label.type = 'text';
    label.value = m.label || '';
    label.addEventListener('input', () => {
      m.label = label.value;
      save();
    });
    frag.append(field('Label', label));

    const radius = document.createElement('input');
    radius.type = 'range';
    radius.min = '1';
    radius.max = '15';
    radius.step = '0.5';
    radius.value = String(m.r);
    radius.addEventListener('input', () => {
      m.r = Number(radius.value);
      syncMarker(m);
      save();
    });
    frag.append(field('Radius', radius));

    const del = document.createElement('button');
    del.type = 'button';
    del.className = 'danger';
    del.textContent = 'Delete plant';
    del.addEventListener('click', () => {
      const i = markers.findIndex((x) => x.id === m.id);
      if (i >= 0) markers.splice(i, 1);
      clearSelection();
      renderMarkers();
      refreshSelection();
      save();
    });
    frag.append(del);
    return frag;
  }

  // ---- pointer interaction ----------------------------------------------

  let drag = null;

  function dropMarker(evt) {
    const p = toLocal(evt);
    const m = {
      id: uid('m-'),
      icon: placeIcon ? placeIcon.icon : '🌱',
      label: placeIcon ? placeIcon.label : '',
      x: round(p.x),
      y: round(p.y),
      r: 3,
    };
    markers.push(m);
    renderMarker(m);
    setTool('select');
    selectMarker(m.id);
    save();
  }

  function onAreaDown(evt, area) {
    if (mode === 'edit' && tool === 'place') {
      evt.stopPropagation();
      dropMarker(evt);
      return;
    }
    evt.stopPropagation();
    if (mode === 'view') {
      selectArea(area.id);
      return;
    }
    selectArea(area.id);
    const start = toLocal(evt);
    const onHandle = evt.target.classList.contains('handle');
    drag = {
      kind: 'area',
      area,
      mode: onHandle ? 'resize' : 'move',
      sx: start.x,
      sy: start.y,
      ox: area.shape.x,
      oy: area.shape.y,
      ow: area.shape.w,
      oh: area.shape.h,
    };
    svg.setPointerCapture(evt.pointerId);
  }

  function onMarkerDown(evt, m) {
    if (mode === 'edit' && tool === 'place') {
      evt.stopPropagation();
      dropMarker(evt);
      return;
    }
    evt.stopPropagation();
    if (mode === 'view') {
      selectMarker(m.id);
      return;
    }
    selectMarker(m.id);
    const start = toLocal(evt);
    const onHandle = evt.target.classList.contains('handle');
    drag = {
      kind: 'marker',
      marker: m,
      mode: onHandle ? 'resize' : 'move',
      sx: start.x,
      sy: start.y,
      ox: m.x,
      oy: m.y,
      or: m.r,
    };
    svg.setPointerCapture(evt.pointerId);
  }

  // background tap: place a marker, or deselect
  svg.addEventListener('pointerdown', (evt) => {
    if (mode === 'edit' && tool === 'place') {
      dropMarker(evt);
      return;
    }
    clearSelection();
  });

  svg.addEventListener('pointermove', (evt) => {
    if (!drag) return;
    const p = toLocal(evt);
    const dx = p.x - drag.sx;
    const dy = p.y - drag.sy;
    if (drag.kind === 'area') {
      if (drag.mode === 'move') {
        drag.area.shape.x = round(drag.ox + dx);
        drag.area.shape.y = round(drag.oy + dy);
      } else {
        drag.area.shape.w = round(Math.max(2, drag.ow + dx));
        drag.area.shape.h = round(Math.max(2, drag.oh + dy));
      }
      syncArea(drag.area);
    } else {
      if (drag.mode === 'move') {
        drag.marker.x = round(drag.ox + dx);
        drag.marker.y = round(drag.oy + dy);
      } else {
        const r = Math.hypot(p.x - drag.marker.x, p.y - drag.marker.y);
        drag.marker.r = round(Math.max(1, r));
      }
      syncMarker(drag.marker);
    }
  });

  function endDrag(evt) {
    if (!drag) return;
    try {
      svg.releasePointerCapture(evt.pointerId);
    } catch {}
    drag = null;
    save();
  }
  svg.addEventListener('pointerup', endDrag);
  svg.addEventListener('pointercancel', endDrag);

  // ---- modes + tools -----------------------------------------------------

  const btnView = document.getElementById('mode-view');
  const btnEdit = document.getElementById('mode-edit');

  function setMode(next) {
    mode = next;
    if (next !== 'edit') setTool('select');
    btnView.classList.toggle('is-active', next === 'view');
    btnEdit.classList.toggle('is-active', next === 'edit');
    editTools.hidden = next !== 'edit';
    svg.classList.toggle('is-editing', next === 'edit');
    refreshSelection();
    renderInfo();
  }

  function setTool(next) {
    tool = next;
    if (next !== 'place') {
      placeIcon = null;
      placeHint.hidden = true;
      svg.classList.remove('is-placing');
      for (const b of palette.querySelectorAll('.icon-btn'))
        b.classList.remove('is-active');
    }
    refreshSelection();
  }

  btnView.addEventListener('click', () => setMode('view'));
  btnEdit.addEventListener('click', () => setMode('edit'));

  document.getElementById('add-area').addEventListener('click', () => {
    const area = {
      id: uid('area-'),
      name: 'New area',
      type: 'bed',
      provisional: true,
      shape: { x: 118, y: 110, w: 14, h: 10 },
    };
    areas.push(area);
    renderArea(area, areas.length);
    selectArea(area.id);
    save();
  });

  // palette
  const palette = document.getElementById('palette');
  for (const it of ICONS) {
    const b = document.createElement('button');
    b.type = 'button';
    b.className = 'icon-btn';
    b.textContent = it.icon;
    b.title = `Drop a ${it.label}`;
    b.addEventListener('click', () => {
      if (tool === 'place' && placeIcon?.icon === it.icon) {
        setTool('select');
        return;
      }
      tool = 'place';
      placeIcon = it;
      placeHint.hidden = false;
      svg.classList.add('is-placing');
      for (const x of palette.querySelectorAll('.icon-btn'))
        x.classList.toggle('is-active', x === b);
      refreshSelection();
    });
    palette.append(b);
  }

  // ---- save actions ------------------------------------------------------

  function buildJSON() {
    return JSON.stringify({ ...plotData, areas, markers }, null, 2);
  }
  document.getElementById('copy-json').addEventListener('click', async () => {
    const text = buildJSON();
    document.getElementById('export-text').value = text;
    try {
      await navigator.clipboard.writeText(text);
    } catch {}
    exportDialog.showModal();
  });
  document.getElementById('download-json').addEventListener('click', () => {
    const blob = new Blob([buildJSON()], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'areas.json';
    a.click();
    URL.revokeObjectURL(a.href);
  });
  document.getElementById('discard').addEventListener('click', () => {
    if (!confirm('Discard local changes on this device and revert to the saved repo version?'))
      return;
    localStorage.removeItem(STORE_KEY);
    const fresh = JSON.parse(baselineJSON);
    areas = fresh.areas;
    markers = fresh.markers;
    clearSelection();
    renderAreas();
    renderMarkers();
    refreshSelection();
    updateSaveState();
  });

  // ---- legend ------------------------------------------------------------

  const legendList = document.getElementById('legend-list');
  for (const [, m] of Object.entries(TYPE_META)) {
    const li = document.createElement('li');
    const sw = document.createElement('span');
    sw.className = 'swatch';
    sw.style.background = m.color;
    li.append(sw, document.createTextNode(m.label));
    legendList.append(li);
  }

  // ---- init --------------------------------------------------------------

  renderAreas();
  renderMarkers();
  refreshSelection();
  renderInfo();
  updateSaveState();
</script>

